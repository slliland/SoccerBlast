@using SoccerBlast.Shared.Contracts
@inject NavigationManager Nav

<div class="team-match-row">
  <div class="team-match-meta">@MetaText</div>

  <div class="team-match-main">
    @if (Match.HomeTeamId > 0)
    {
      <a href="/team/@Match.HomeTeamId" class="team-match-crest-link">
        <img class="team-match-crest"
             src="@HomeCrest"
             alt="@Match.HomeTeamName"
             loading="lazy"
             referrerpolicy="no-referrer"
             onerror="this.onerror=null; this.src='/images/teams/placeholder.png';" />
      </a>
      <a href="/team/@Match.HomeTeamId" class="team-match-team team-match-team-link">@Match.HomeTeamName</a>
    }
    else
    {
      <img class="team-match-crest"
           src="@HomeCrest"
           alt="@Match.HomeTeamName"
           loading="lazy"
           referrerpolicy="no-referrer"
           onerror="this.onerror=null; this.src='/images/teams/placeholder.png';" />
      <span class="team-match-team" title="@Match.HomeTeamName">@Match.HomeTeamName</span>
    }

    @if (!string.IsNullOrWhiteSpace(Match.ExternalId))
    {
      <a href="/match/@Match.ExternalId" class="team-match-score team-match-score-link">@ScoreText</a>
    }
    else
    {
      <span class="team-match-score">@ScoreText</span>
    }

    @if (Match.AwayTeamId > 0)
    {
      <a href="/team/@Match.AwayTeamId" class="team-match-team team-match-team-link">@Match.AwayTeamName</a>
      <a href="/team/@Match.AwayTeamId" class="team-match-crest-link">
        <img class="team-match-crest"
             src="@AwayCrest"
             alt="@Match.AwayTeamName"
             loading="lazy"
             referrerpolicy="no-referrer"
             onerror="this.onerror=null; this.src='/images/teams/placeholder.png';" />
      </a>
    }
    else
    {
      <span class="team-match-team" title="@Match.AwayTeamName">@Match.AwayTeamName</span>
      <img class="team-match-crest"
           src="@AwayCrest"
           alt="@Match.AwayTeamName"
           loading="lazy"
           referrerpolicy="no-referrer"
           onerror="this.onerror=null; this.src='/images/teams/placeholder.png';" />
    }
  </div>

  <div class="team-match-comp">
    @if (Match.CompetitionId > 0)
    {
      <a href="/competition/@Match.CompetitionId" class="team-match-comp-name team-match-comp-link">@(!string.IsNullOrWhiteSpace(Match.CompetitionName) ? Match.CompetitionName : "—")</a>
    }
    else
    {
      <span class="team-match-comp-name">@(!string.IsNullOrWhiteSpace(Match.CompetitionName) ? Match.CompetitionName : "—missing—")</span>
    }
  </div>
</div>

@code {
  [Parameter, EditorRequired] public MatchDto Match { get; set; } = default!;
  [Parameter] public string TimeZoneId { get; set; } = "America/New_York";

  private string HomeCrest => string.IsNullOrWhiteSpace(Match.HomeTeamCrestUrl) ? "/images/teams/placeholder.png" : Match.HomeTeamCrestUrl!;
  private string AwayCrest => string.IsNullOrWhiteSpace(Match.AwayTeamCrestUrl) ? "/images/teams/placeholder.png" : Match.AwayTeamCrestUrl!;

  private string ScoreText =>
    (Match.HomeScore.HasValue && Match.AwayScore.HasValue)
      ? $"{Match.HomeScore}-{Match.AwayScore}"
      : "vs";

  private string MetaText
  {
    get
    {
      var tz = TimeZoneInfo.FindSystemTimeZoneById(TimeZoneId);
      var utc = Match.UtcDate.UtcDateTime;
      var local = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), tz);
      return local.ToString("MMM d, yyyy • h:mm tt");
    }
  }
}
