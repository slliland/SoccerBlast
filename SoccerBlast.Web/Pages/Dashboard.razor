  private List<MatchDto> VisibleMatches()
  {
    IEnumerable<MatchDto> q = _matches;

    if (_selectedCompetitionId != -1)
    {
      // League selected in sidebar: show only that league's matches (ignore scope)
      return q.Where(m => m.CompetitionId == _selectedCompetitionId).ToList();
    }

    // "All" selected: apply scope filter
    if (_matchScope == "following")
    {
        var followedIds = _prefs.FollowedTeamIds?.Where(id => id != 0).ToHashSet() ?? new HashSet<int>();
        if (followedIds.Count > 0)
            q = q.Where(m => followedIds.Contains(m.HomeTeamId) || followedIds.Contains(m.AwayTeamId));
    }
    else if (_matchScope == "popular")
    {
        q = q.Where(m => IsPopularLeague(m.CompetitionId, m.CompetitionName));
    }
    else if (_matchScope == "national")
    {
        q = q.Where(m => LeagueTierService.GetTier(m.CompetitionName) == LeagueTierService.InternationalNational);
    }
    else if (_prefs.FollowedTeamsOnly)
    {
        var followedIds = _prefs.FollowedTeamIds?.Where(id => id != 0).ToHashSet() ?? new HashSet<int>();
        if (followedIds.Count > 0)
            q = q.Where(m => followedIds.Contains(m.HomeTeamId) || followedIds.Contains(m.AwayTeamId));
    }

    return q.ToList();
  }

  private static readonly (string Section, string Label, string? IconPath)[] SectionOrder =
  {
      ("Popular", "Popular", "images/icons/popular.png"),
      ("International", "International", "images/icons/international.png"),
      ("Domestic", "Domestic Leagues", "images/icons/domestic.png"),
      ("Cups", "Cups", "images/icons/cups.png"),
      ("More", "More", null)
  };

  private static string GetSectionForTier(string tier)
  {
      if (tier == LeagueTierService.InternationalNational) return "International";
      if (tier == LeagueTierService.ContinentalClub) return "Popular";
      if (tier == LeagueTierService.DomesticTop) return "Domestic";
      if (tier == LeagueTierService.DomesticCups) return "Cups";
      return "More";
  }

  private static IReadOnlyList<(string Label, string? IconPath, List<LeagueDto> Leagues)> GroupLeaguesBySection(List<LeagueDto> leagues)
  {
      var tierGroups = LeagueTierService.GroupByTier(leagues);
      var bySection = new Dictionary<string, List<LeagueDto>>(StringComparer.OrdinalIgnoreCase);
      foreach (var (section, _, _) in SectionOrder)
          bySection[section] = new List<LeagueDto>();
      foreach (var (tierLabel, tierLeagues) in tierGroups)
      {
          var section = GetSectionForTier(tierLabel);
          bySection[section].AddRange(tierLeagues);
      }
      return SectionOrder
          .Where(s => bySection[s.Section].Count > 0)
          .Select(s => (s.Label, s.IconPath, bySection[s.Section]))
          .ToList();
  }

  private static bool IsPopularLeague(int competitionId, string? name) => LeagueTierService.IsRecommendedPopular(competitionId, name);

  private List<MatchDto> GetLiveMatches()
  {
    return _matches
        .Where(m => MatchDisplayHelper.IsLiveStatus(m.Status))
        .OrderByDescending(m => IsPopularLeague(m.CompetitionId, m.CompetitionName))
        .ThenBy(m => m.UtcDate)
        .ToList();
  }

  private List<MatchDto> GetPopularTodayMatches()
  {
    return _matches
        .Where(m => !MatchDisplayHelper.IsLiveStatus(m.Status) && IsPopularLeague(m.CompetitionId, m.CompetitionName))
        .OrderBy(m => m.UtcDate)
        .ToList();
  }

  private List<MatchDto> GetYourTeamsMatches()
  {
    var followedIds = _prefs.FollowedTeamIds?.Where(id => id != 0).ToHashSet() ?? new HashSet<int>();
    if (followedIds.Count == 0) return new List<MatchDto>();
    return _matches
        .Where(m => followedIds.Contains(m.HomeTeamId) || followedIds.Contains(m.AwayTeamId))
        .OrderBy(m => m.UtcDate)
        .ToList();
  }


  private string _tzId = "America/New_York";

  private string FormatLocalTime(DateTime utcDate)
  {
    var tz = TimeZoneInfo.FindSystemTimeZoneById(_tzId);
    var local = TimeZoneInfo.ConvertTimeFromUtc(
        DateTime.SpecifyKind(utcDate, DateTimeKind.Utc),
        tz
    );
    return local.ToString("HH:mm");
  }

  private string FormatLocalTime(DateTimeOffset utcDate) => FormatLocalTime(utcDate.UtcDateTime);

  private static IReadOnlyList<KeyValuePair<string, List<MatchDto>>> GroupByCompetition(List<MatchDto> matches)
  {
    var tierOrder = new[]
    {
      LeagueTierService.InternationalNational,
      LeagueTierService.ContinentalClub,
      LeagueTierService.DomesticTop,
      LeagueTierService.DomesticCups,
      LeagueTierService.InternationalClub,
      LeagueTierService.OtherRegional
    };
    return matches
      .GroupBy(m => m.CompetitionName ?? "Other")
      .OrderBy(g => Array.IndexOf(tierOrder, LeagueTierService.GetTier(g.Key)))
      .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
      .Select(g => new KeyValuePair<string, List<MatchDto>>(g.Key, g.ToList()))
      .ToList();
  }

  private static List<LeagueDto> BuildLeagues(List<MatchDto> matches)
  {
    return matches
        .GroupBy(m => new { m.CompetitionId, m.CompetitionName, m.CompetitionBadgeUrl })
        .Select(g => new LeagueDto
        {
            CompetitionId = g.Key.CompetitionId,
            Name = g.Key.CompetitionName ?? "Other",
            BadgeUrl = g.Key.CompetitionBadgeUrl,
            MatchCount = g.Count(),
            LiveCount = g.Count(x => MatchDisplayHelper.IsLiveStatus(x.Status))
        })
        .OrderByDescending(x => x.LiveCount)
        .ThenByDescending(x => x.MatchCount)
        .ThenBy(x => x.Name)
        .ToList();
  }
