@page "/"
@using SoccerBlast.Shared.Contracts
@inject SoccerBlast.Web.Services.SoccerApiClient Api
@using SoccerBlast.Web.Services
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer
@inject SoccerBlast.Web.Services.BrowserTimeZone Tz
@inject SoccerBlast.Web.Services.UserPrefsStore Prefs
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@implements IDisposable

<div class="sb-page" @onclick="CloseOverlays">
    <div class="sb-shell">
    <div class="sb-card sb-topbar">
        <div class="sb-brand">
        <img class="sb-logo" src="images/logo/soccer-blast.png" alt="Soccer Blast" />
        <div>Soccer Blast</div>
        </div>

        <div class="sb-tabs">
        <NavLink href="/" Match="NavLinkMatch.All">Live Scores</NavLink>
        <NavLink href="/all">All Match</NavLink>
        <NavLink href="/video">Video</NavLink>
        <NavLink href="/news">News</NavLink>
        <NavLink href="/stats">Stats</NavLink>
        <NavLink href="/rankings">Rankings</NavLink>
        </div>
        <div class="sb-search" @onclick:stopPropagation="true">
            <input class="sb-search-input"
                    placeholder="Search teams, matches, leagues, news…"
                    value="@_q"
                    @oninput="OnSearchInput"
                    @onfocus="OpenSearch" />

            @if (_showSearch)
            {
                <div class="sb-search-pop">
                @if (_searchLoading)
                {
                    <div class="sb-search-row muted">Searching…</div>
                }
                else if (_results.Count == 0 && _q.Trim().Length >= 2)
                {
                    <div class="sb-search-row muted">No results</div>
                }
                else
                {
                    @foreach (var r in _results)
                    {
                    <a class="sb-search-row"
                        href="@ResolveHref(r)"
                        target="@(IsExternal(r) ? "_blank" : null)"
                        rel="@(IsExternal(r) ? "noopener noreferrer" : null)"
                        @onclick="CloseSearch"
                        @onclick:stopPropagation="true">
                        <div class="sb-search-title">@r.Title</div>
                        <div class="sb-search-sub"><b>@r.Type</b> · @r.Subtitle</div>
                    </a>
                    }
                }
                </div>
            }
            </div>
        <NavLink class="sb-avatar" title="Profile" href="/settings" @onclick:stopPropagation="true"></NavLink>
    </div>

    <div class="sb-grid">

        <!-- LEFT: Leagues -->
        <div class="sb-left">
        <div class="sb-card sb-left-card">
            <div class="sb-section-title">Football Leagues</div>
            <div class="sb-league-filter-wrap" @onclick:stopPropagation="true">
                <input type="text"
                       class="sb-league-filter"
                       placeholder="Find league…"
                       value="@_leagueFilter"
                       @oninput="OnLeagueFilterInput" />
            </div>
            <div class="sb-left-scroll">
            <div class="sb-list">
                <button class="@(_selectedCompetitionId == -1 ? "active" : "")"
                        @onclick="() => SelectCompetition(-1)">
                <span class="league-row">
                    <img class="league-ic-img" src="images/icons/football-pitch.png" alt="All" />
                    <span>All</span>
                </span>
                <span class="league-meta">@_matches.Count</span>
                </button>

                @foreach (var group in LeagueTierService.GroupByTier(FilteredLeagues()))
                {
                <div class="sb-tier-group">
                    <div class="sb-tier-title">@group.TierLabel</div>
                    @foreach (var l in group.Leagues)
                    {
                    <button class="@(l.CompetitionId == _selectedCompetitionId ? "active" : "")"
                            @onclick="() => SelectCompetition(l.CompetitionId)">
                        <span class="league-row">
                        <img class="league-ic-img" src="@(l.BadgeUrl ?? LeagueIconMap.Get(l.CompetitionId, l.Name))" alt="@l.Name" />
                        <span>@l.Name</span>
                        @if (l.LiveCount > 0)
                        {
                            <span class="badge-live">Live</span>
                        }
                        </span>
                        <span class="league-meta">@l.MatchCount</span>
                    </button>
                    }
                </div>
                }
            </div>
            </div>
        </div>
        </div>


        <!-- MAIN -->
        <div class="sb-card sb-main">
        <div class="hero hero-banner">
            <img class="hero-img" src="images/banner/banner.png" alt="Banner" />
        </div>

        <div class="sb-main-matches-card">
        <div class="section-head">
            <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;">
                <h4 style="margin:0;">Matches</h4>
                <span class="small-muted">Updated @_matchesUpdatedLocal.ToString("HH:mm")</span>
            </div>
            <div class="small-muted">
            <button class="btn" style="padding:8px 10px;border-radius:12px;" @onclick="PrevDay">◀</button>
            <span class="sb-datewrap" @onclick:stopPropagation="true">
               <button class="sb-datebtn"
                        @onclick="ToggleCalendar"
                        @onclick:stopPropagation="true">
                @_viewDate.ToString("MMM dd, yyyy")
                </button>

                @if (_showCalendar)
                {
                    <div class="sb-cal" @onclick:stopPropagation="true">
                    <div class="sb-cal-head">
                        <button class="sb-cal-nav" @onclick="PrevMonth">‹</button>
                        <div class="sb-cal-title">@_calMonth.ToString("MMMM yyyy")</div>
                        <button class="sb-cal-nav" @onclick="NextMonth">›</button>
                    </div>

                    <div class="sb-cal-dow">
                        @foreach (var d in _dow)
                        {
                        <div class="sb-cal-dowcell">@d</div>
                        }
                    </div>

                    <div class="sb-cal-grid">
                        @foreach (var cell in BuildCalendarCells(_calMonth))
                        {
                        <button class="@GetCellClass(cell)"
                                disabled="@cell.IsDisabled"
                                @onclick="() => PickDate(cell.Date)">
                            @cell.DayNumber
                        </button>
                        }
                    </div>

                <div class="sb-cal-actions">
                        <button class="sb-cal-action" @onclick="GoToday">Today</button>
                        <button class="sb-cal-action" @onclick="CloseCalendar">Close</button>
                    </div>
                    </div>
                }
                </span>
            <button class="btn" style="padding:8px 10px;border-radius:12px;" @onclick="NextDay">▶</button>
            </div>
        </div>

        @if (_loading)
        {
            <GlobalSpinner Message="Loading matches…" />
        }
        else if (_matches.Count == 0)
        {
            <p class="small-muted">No matches found for this day.</p>
        }
        else
        {
            @foreach (var group in GroupByCompetition(VisibleMatches()))
            {
            <div class="block">
                <div class="block-title">
                <span>@group.Key</span>
                <span class="small-muted">@_viewDate.ToString("dd/MM/yyyy")</span>
                </div>

                @foreach (var m in group.Value)
                {
                <div class="match-row">
                    <div class="time-pill">@FormatLocalTime(m.UtcDate)</div>

                    <div class="team">
                        <img class="team-crest"
                            src="@(string.IsNullOrWhiteSpace(m.HomeTeamCrestUrl) ? "images/teams/placeholder.png" : m.HomeTeamCrestUrl)"
                            alt="@m.HomeTeamName"
                            loading="lazy"
                            decoding="async"
                            referrerpolicy="no-referrer"
                            onload="this.classList.add('loaded');"
                            onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                            @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")'
                            style="cursor: pointer;" />
                        <div class="name-row">
                            <div class="name" title="@m.HomeTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;">@m.HomeTeamName</div>
                            <button class="sb-likebtn @(IsLikedTeam(m.HomeTeamId) ? "liked" : "")"
                                    title="Like team"
                                    @onclick="() => ToggleLikeTeam(m.HomeTeamId, m.HomeTeamName, m.HomeTeamCrestUrl)"
                                    @onclick:stopPropagation="true">
                                <img class="sb-likeimg"
                                    src="@TeamLikeIcon(m.HomeTeamId)"
                                    alt="like" />
                            </button>
                        </div>
                    </div>

                    <div class="team">
                        <img class="team-crest"
                            src="@(string.IsNullOrWhiteSpace(m.AwayTeamCrestUrl) ? "images/teams/placeholder.png" : m.AwayTeamCrestUrl)"
                            alt="@m.AwayTeamName"
                            loading="lazy"
                            decoding="async"
                            referrerpolicy="no-referrer"
                            onload="this.classList.add('loaded');"
                            onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                            @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")'
                            style="cursor: pointer;" />
                        <div class="name-row">
                            <div class="name" title="@m.AwayTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;">@m.AwayTeamName</div>
                            <button class="sb-likebtn @(IsLikedTeam(m.AwayTeamId) ? "liked" : "")"
                                    title="Like team"
                                    @onclick="() => ToggleLikeTeam(m.AwayTeamId, m.AwayTeamName, m.AwayTeamCrestUrl)"
                                    @onclick:stopPropagation="true">
                                <img class="sb-likeimg"
                                    src="@TeamLikeIcon(m.AwayTeamId)"
                                    alt="like" />
                            </button>
                        </div>
                    </div>


                    <div class="score">
                    <div class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</div>
                    <div class="num">:</div>
                    <div class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</div>

                    <div class="status @(MatchDisplayHelper.IsLiveStatus(m.Status) ? "live" : "")">
                        @m.Status
                    </div>
                    </div>
                </div>
                }
            </div>
            }
        }
        </div>
        </div>

        <!-- RIGHT: News -->
        <div class="sb-right sb-card">
        <div class="section-head">
            <h4>Recent News</h4>
            <span class="small-muted">Updated @_nowLocal.ToString("HH:mm")</span>
        </div>

        @foreach (var n in _news)
        {
            <div class="news-item">
                <img class="news-thumb-img"
                    src="@(string.IsNullOrWhiteSpace(n.ThumbnailUrl) ? "images/news/placeholder.png" : n.ThumbnailUrl)"
                    alt=""
                    loading="lazy"
                    referrerpolicy="no-referrer"
                    onerror="this.src='images/news/placeholder.png';" />

                <div>
                <p class="news-title">
                    <a href="@n.Url" target="_blank" rel="noopener noreferrer">@n.Title</a>
                </p>
                <div class="news-meta">@n.Source • @MatchDisplayHelper.FormatRelativeTime(n.PublishedAt)</div>
                </div>
            </div>
        }
        </div>
    </div>
  </div>
</div>

@code {
  private bool _loading = true;

  private string? _toast;

  private DateOnly _viewDate;
  private List<MatchDto> _matches = new();

  private int _selectedCompetitionId = -1; // -1 = All
  private List<LeagueDto> _leagues = new();

  // news
  private List<NewsDto> _news = new();
  private DateTime _nowLocal = DateTime.Now;
  private AutoSyncLoop? _clockLoop;
  private AutoSyncLoop? _newsLoop;
  private AutoSyncLoop? _matchLoop;

  // calendar  
  private bool _showCalendar;
  private DateTime _calMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
  private static readonly string[] _dow = ["Su","Mo","Tu","We","Th","Fr","Sa"];

  // sync matches
  private DateTime _matchesUpdatedLocal = DateTime.Now;

  // search
  private string _q = "";
  private bool _showSearch;
  private bool _searchLoading;
  private List<SearchResultDto> _results = new();
  private CancellationTokenSource? _searchCts;

  // league sidebar filter (small find-league input)
  private string _leagueFilter = "";

  private void OpenSearch() => _showSearch = true;
  private void CloseSearch() => _showSearch = false;

  private void OnLeagueFilterInput(ChangeEventArgs e)
  {
    _leagueFilter = (e.Value?.ToString() ?? "").Trim();
    StateHasChanged();
  }

  private List<LeagueDto> FilteredLeagues()
  {
    if (string.IsNullOrWhiteSpace(_leagueFilter))
      return _leagues;
    return _leagues
      .Where(l => (l.Name ?? "").Contains(_leagueFilter, StringComparison.OrdinalIgnoreCase))
      .ToList();
  }

  // like/unlike team
  private bool IsLikedTeam(int teamId) 
    => TeamLikeHelper.IsLiked(teamId, _prefs.FollowedTeamIds);

  private string TeamLikeIcon(int teamId)
    => TeamLikeHelper.GetLikeIconPath(teamId, _prefs.FollowedTeamIds);

  private async Task ToggleLikeTeam(int teamId, string teamName, string? teamCrestUrl)
  {
    await TeamLikeHelper.ToggleLikeAsync(teamId, teamName, teamCrestUrl, _prefs.FollowedTeamIds, Prefs, async () =>
    {
      await InvokeAsync(StateHasChanged);
    });
  }

  private string? _lastPath;

  protected override void OnInitialized()
  {
    _lastPath = new Uri(Nav.Uri).AbsolutePath;
    Nav.LocationChanged += OnLocationChanged;
  }

  private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
  {
    if (!_hydrated) return;

    var path = new Uri(e.Location).AbsolutePath;

    // only reload when returning to "/"
    if (path == "/")
    {
        try
        {
            var prefs = await Prefs.GetAsync();
            await InvokeAsync(() =>
            {
                _prefs = prefs;
                StateHasChanged();
            });
        }
        catch { }
    } 
  }


  private async Task OnSearchInput(ChangeEventArgs e)
  {
    _q = e.Value?.ToString() ?? "";
    _showSearch = true;

    _searchCts?.Cancel();
    _searchCts?.Dispose();
    _searchCts = new CancellationTokenSource();
    var token = _searchCts.Token;

    _searchLoading = _q.Trim().Length >= 2;
    StateHasChanged();

    try
    {
        // debounce
        await Task.Delay(250, token);

        if (_q.Trim().Length < 2)
        {
            _searchLoading = false;
            _results.Clear();
            StateHasChanged();
            return;
        }

        var res = await Api.SearchAsync(_q, 12);
        if (token.IsCancellationRequested) return;

        _results = res;
        _searchLoading = false;
        StateHasChanged();
    }
    catch (TaskCanceledException) { }
    catch
    {
        _searchLoading = false;
        StateHasChanged();
    }
  }

  private static bool IsExternal(SearchResultDto r)
    => r.Type == SearchResultType.News && (r.Url?.StartsWith("http", StringComparison.OrdinalIgnoreCase) ?? false);

  private static string ResolveHref(SearchResultDto r)
    => string.IsNullOrWhiteSpace(r.Url) ? "#" : r.Url!;


  private void ToggleCalendar()
  {
    _showCalendar = !_showCalendar;
    if (_showCalendar)
    {
        // open calendar at currently selected date's month
        _calMonth = new DateTime(_viewDate.Year, _viewDate.Month, 1);
    }
  }

  private void CloseCalendar() => _showCalendar = false;

  private void CloseOverlays()
  {
    _showCalendar = false;
    _showSearch = false;
  }

  private void PrevMonth() => _calMonth = _calMonth.AddMonths(-1);
  private void NextMonth() => _calMonth = _calMonth.AddMonths(1);

  private async Task GoToday()
  {
    _viewDate = DateOnly.FromDateTime(DateTime.Now);
    _calMonth = new DateTime(_viewDate.Year, _viewDate.Month, 1);
    _showCalendar = false;
    await LoadForDate(_viewDate);
  }

  private async Task PickDate(DateOnly d)
  {
    _viewDate = d;
    _showCalendar = false;
    await LoadForDate(_viewDate);
  }

  private sealed record CalCell(DateOnly Date, int DayNumber, bool IsInCurrentMonth, bool IsDisabled);

  private List<CalCell> BuildCalendarCells(DateTime month)
  {
    var first = new DateTime(month.Year, month.Month, 1);
    var start = first.AddDays(-(int)first.DayOfWeek); // Sunday-start

    var cells = new List<CalCell>(42);
    for (int i = 0; i < 42; i++)
    {
        var day = start.AddDays(i);
        var d = DateOnly.FromDateTime(day);
        var inMonth = day.Month == month.Month;
        cells.Add(new CalCell(d, day.Day, inMonth, false));
    }
    return cells;
  }

  private string GetCellClass(CalCell cell)
  {
    var cls = "sb-cal-day";
    if (!cell.IsInCurrentMonth) cls += " muted";
    if (cell.Date == DateOnly.FromDateTime(DateTime.Now)) cls += " today";
    if (cell.Date == _viewDate) cls += " selected";
    return cls;
  }

  private UserPrefs _prefs = new();
  private bool _hydrated;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!firstRender) return;

    _tzId = await Tz.GetTimeZoneIdAsync();
    _nowLocal = ConvertUtcToLocal(DateTime.UtcNow);
    Api.SetTimeZone(_tzId);

    _prefs = await Prefs.GetAsync();
    _viewDate = DateOnly.FromDateTime(DateTime.Now);

    _hydrated = true;

    StartLoops();
    await LoadForDate(_viewDate);
  }


  private DateTime ConvertUtcToLocal(DateTime utc)
  {
    var tz = TimeZoneInfo.FindSystemTimeZoneById(_tzId);
    return TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), tz);
  } 

  private void StartLoops()
  {
    // Match sync loop - refresh current date every 60s
    _matchLoop = new AutoSyncLoop(TimeSpan.FromSeconds(60), async _ =>
    {
        var d = _viewDate;
        await Api.SyncByLocalDateAsync(d);
        var fresh = await Api.GetByLocalDateAsync(d);
        await InvokeAsync(() =>
        {
            _matches = fresh;
            _leagues = BuildLeagues(_matches);
            _matchesUpdatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
            StateHasChanged();
        });
    });
    _matchLoop.Start();

    // Clock loop - update time display every 10s
    _clockLoop = new AutoSyncLoop(TimeSpan.FromSeconds(10), async _ =>
    {
        await InvokeAsync(() =>
        {
            _nowLocal = ConvertUtcToLocal(DateTime.UtcNow);
            StateHasChanged();
        });
    });
    _clockLoop.Start();

    // News refresh loop - fetch news every 60s
    _newsLoop = new AutoSyncLoop(TimeSpan.FromSeconds(60), async _ =>
    {
        var news = await Api.GetRecentNewsAsync(10);
        await InvokeAsync(() =>
        {
            _news = news;
            StateHasChanged();
        });
    });
    _newsLoop.Start();
  }

  public void Dispose()
  {
    Nav.LocationChanged -= OnLocationChanged;
    
    _matchLoop?.Dispose();
    _clockLoop?.Dispose();
    _newsLoop?.Dispose();
    
    _searchCts?.Cancel();
    _searchCts?.Dispose();
  }

  private async Task LoadForDate(DateOnly d)
  {
    _selectedCompetitionId = -1;

    // Immediately show whatever is already in DB (fast)
    _loading = true;
    _toast = null;
    StateHasChanged();

    try
    {
      _matches = await Api.GetByLocalDateAsync(d) ?? new();
      _leagues = BuildLeagues(_matches);
      _matchesUpdatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
    }
    catch (Exception ex)
    {
      _matches = new();
      _leagues = new();
      _toast = $"Could not load matches: {ex.Message}";
    }
    finally
    {
      _loading = false;
    }
    StateHasChanged();

    // Load news in parallel (don’t block UI)
    _ = Task.Run(async () =>
    {
        try
        {
            var news = await Api.GetRecentNewsAsync(10);
            await InvokeAsync(() =>
            {
                _news = news;
                StateHasChanged();
            });
        }
        catch { /* ignore */ }
    });

    // Sync in background, then refresh matches
    try
    {
        var synced = await Api.SyncByLocalDateAsync(d);
        if (synced > 0)
        {
            _toast = $"Updated {synced} matches.";
            var fresh = await Api.GetByLocalDateAsync(d) ?? new();
            await InvokeAsync(() =>
            {
                _matches = fresh;
                _matchesUpdatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
                _leagues = BuildLeagues(_matches);
                StateHasChanged();
            });
        }
    }
    catch (Exception ex)
    {
        _toast = $"Sync failed: {ex.Message}";
        await InvokeAsync(StateHasChanged);
    }
  }

  private void SelectCompetition(int competitionId)
  {
    _selectedCompetitionId = competitionId;
    _toast = null;
  }

  private async Task PrevDay()
  {
    _viewDate = _viewDate.AddDays(-1);
    await LoadForDate(_viewDate);
  }

  private async Task NextDay()
  {
    _viewDate = _viewDate.AddDays(1);
    await LoadForDate(_viewDate);
  }

  private List<MatchDto> VisibleMatches()
  {
    IEnumerable<MatchDto> q = _matches;

    if (_selectedCompetitionId != -1)
        q = q.Where(m => m.CompetitionId == _selectedCompetitionId);

    if (_prefs.FollowedTeamsOnly && _prefs.FollowedTeamIds.Count > 0)
        q = q.Where(m => _prefs.FollowedTeamIds.Contains(m.HomeTeamId) ||
                         _prefs.FollowedTeamIds.Contains(m.AwayTeamId));

    return q.ToList();
  }

  private string _tzId = "America/New_York";

  private string FormatLocalTime(DateTime utcDate)
  {
    // utcDate should represent UTC from API
    var tz = TimeZoneInfo.FindSystemTimeZoneById(_tzId);
    var local = TimeZoneInfo.ConvertTimeFromUtc(
        DateTime.SpecifyKind(utcDate, DateTimeKind.Utc),
        tz
    );
    return local.ToString("HH:mm");
  }

  private static IReadOnlyList<KeyValuePair<string, List<MatchDto>>> GroupByCompetition(List<MatchDto> matches)
  {
    var tierOrder = new[]
    {
      LeagueTierService.InternationalNational,
      LeagueTierService.ContinentalClub,
      LeagueTierService.DomesticTop,
      LeagueTierService.DomesticCups,
      LeagueTierService.InternationalClub,
      LeagueTierService.OtherRegional
    };
    return matches
      .GroupBy(m => m.CompetitionName ?? "Other")
      .OrderBy(g => Array.IndexOf(tierOrder, LeagueTierService.GetTier(g.Key)))
      .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
      .Select(g => new KeyValuePair<string, List<MatchDto>>(g.Key, g.ToList()))
      .ToList();
  }

  private static List<LeagueDto> BuildLeagues(List<MatchDto> matches)
  {
    return matches
        .GroupBy(m => new { m.CompetitionId, m.CompetitionName, m.CompetitionBadgeUrl })
        .Select(g => new LeagueDto
        {
            CompetitionId = g.Key.CompetitionId,
            Name = g.Key.CompetitionName ?? "Other",
            BadgeUrl = g.Key.CompetitionBadgeUrl,
            MatchCount = g.Count(),
            LiveCount = g.Count(x => MatchDisplayHelper.IsLiveStatus(x.Status))
        })
        .OrderByDescending(x => x.LiveCount)
        .ThenByDescending(x => x.MatchCount)
        .ThenBy(x => x.Name)
        .ToList();
  }
}
