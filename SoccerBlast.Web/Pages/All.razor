@page "/all"
@using SoccerBlast.Shared.Contracts
@using SoccerBlast.Web.Services
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer

@inject SoccerApiClient Api
@inject BrowserTimeZone Tz
@inject UserPrefsStore Prefs
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="sb-page all-page" @onclick="CloseOverlays">
  <div class="sb-shell">

    <!-- TOP BAR -->
    <div class="sb-card sb-topbar">
      <div class="sb-brand">
        <img class="sb-logo" src="images/logo/soccer-blast.png" alt="Soccer Blast" />
        <div>Soccer Blast</div>
      </div>

      <div class="sb-tabs">
        <NavLink href="/" Match="NavLinkMatch.All">Live Scores</NavLink>
        <NavLink href="/all" Match="NavLinkMatch.All">All Match</NavLink>
        <NavLink href="/video">Video</NavLink>
        <NavLink href="/news">News</NavLink>
        <NavLink href="/stats">Stats</NavLink>
        <NavLink href="/rankings">Rankings</NavLink>
      </div>

      <div class="sb-search" @onclick:stopPropagation="true">
        <input class="sb-search-input"
               placeholder="Search teams, matches, leagues, news…"
               value="@_q"
               @oninput="OnSearchInput"
               @onfocus="OpenSearch" />

        @if (_showSearch)
        {
          <div class="sb-search-pop">
            @if (_searchLoading)
            {
              <div class="sb-search-row muted">Searching…</div>
            }
            else if (_results.Count == 0 && _q.Trim().Length >= 2)
            {
              <div class="sb-search-row muted">No results</div>
            }
            else
            {
              @foreach (var r in _results)
              {
                <a class="sb-search-row"
                   href="@ResolveHref(r)"
                   target="@(IsExternal(r) ? "_blank" : null)"
                   rel="@(IsExternal(r) ? "noopener noreferrer" : null)"
                   @onclick="CloseSearch"
                   @onclick:stopPropagation="true">
                  <div class="sb-search-title">@r.Title</div>
                  <div class="sb-search-sub"><b>@r.Type</b> · @r.Subtitle</div>
                </a>
              }
            }
          </div>
        }
      </div>

      <NavLink class="sb-avatar" title="Profile" href="/settings" @onclick:stopPropagation="true"></NavLink>
    </div>

    <!-- BODY -->
    <div class="sb-card sb-main">

      <div class="all-jump-bar section-head">
        <div class="all-header">
          <h4>All Matches</h4>
          <span class="small-muted">
            @(_hydrated ? $"Updated {_updatedLocal:HH:mm}" : "Loading…")
          </span>
        </div>

        <div class="all-controls">
          <div class="all-row">
            <div class="all-range-group">
              <span class="all-label">Range</span>
              <input type="date" class="sb-dateinput"
                     value="@_startDate.ToString("yyyy-MM-dd")"
                     @onchange="OnStartChanged" />
              <img class="am-arrow-img" src="images/all/arrow-right.png" alt="to" />
              <input type="date" class="sb-dateinput"
                     value="@_endDate.ToString("yyyy-MM-dd")"
                     @onchange="OnEndChanged" />
            </div>

            <div class="all-presets">
              <button class="btn btn-sm @(PresetKind() == "today" ? "active" : "")" @onclick="SetToday">Today</button>
              <button class="btn btn-sm @(PresetKind() == "tomorrow" ? "active" : "")" @onclick="SetTomorrow">Tomorrow</button>
              <button class="btn btn-sm @(PresetKind() == "yesterday" ? "active" : "")" @onclick="SetYesterday">Yesterday</button>
              <button class="btn btn-sm @(PresetKind() == "7d" ? "active" : "")" @onclick="Set7Days">7d</button>
              <button class="btn btn-sm @(PresetKind() == "30d" ? "active" : "")" @onclick="Set30Days">30d</button>
            </div>
          </div>

          <div class="all-row all-jump-row">
            <div class="all-inline-filter-wrap">
              <button type="button" class="all-teams-filter-btn @(_inlineFilter.Length > 0 ? "active" : "")" @onclick="FocusTeamFilter" title="Filter by team or league">Teams</button>
              <input type="text" class="sb-inline-filter"
                     id="all-team-league-filter"
                     placeholder="Filter by team or league…"
                     value="@_inlineFilter"
                     @oninput="OnInlineFilterInput" />
            </div>
            <div class="all-view-mode">
              <span class="all-label">View</span>
              <button type="button" class="btn btn-sm @(_viewMode == "day" ? "active" : "")" @onclick='() => _viewMode = "day"'>By Day</button>
              <button type="button" class="btn btn-sm @(_viewMode == "league" ? "active" : "")" @onclick='() => _viewMode = "league"'>By League</button>
              <button type="button" class="btn btn-sm @(_viewMode == "agenda" ? "active" : "")" @onclick='() => _viewMode = "agenda"'>Agenda</button>
            </div>
          </div>

          <div class="all-row">
            <div class="all-filter-group">
              <span class="all-label">League</span>
              <div class="sb-filter-custom" @onclick:stopPropagation="true">
                <button class="sb-filter-btn" @onclick="ToggleLeagueDropdown">
                  <span class="sb-filter-text">
                    @(string.IsNullOrWhiteSpace(_selectedCompetitionName) ? $"All leagues ({VisibleMatchesRaw().Count})" : $"{_selectedCompetitionName} ({VisibleMatches().Count})")
                  </span>
                  <span class="sb-filter-arrow">▾</span>
                </button>

                @if (_showLeagueDropdown)
                {
                  <div class="sb-filter-menu sb-filter-menu-tiered">
                    <div class="sb-league-filter-inmenu" @onclick:stopPropagation="true">
                      <input type="text"
                             class="sb-league-filter"
                             placeholder="Find league…"
                             value="@_leagueFilter"
                             @oninput="OnLeagueFilterInput" />
                    </div>
                    <button class="sb-filter-option @(string.IsNullOrWhiteSpace(_selectedCompetitionName) ? "active" : "")"
                            @onclick='() => SelectLeague("")'>
                      All leagues (@VisibleMatchesRaw().Count)
                    </button>
                    @foreach (var group in LeagueTierService.GroupOptionsByTier(FilteredLeagueOptions().Select(x => (x.Name, x.Count))))
                    {
                      <div class="sb-filter-tier-group">
                        <div class="sb-filter-tier-title">@group.TierLabel</div>
                        @foreach (var l in group.Leagues)
                        {
                          <button class="sb-filter-option @(_selectedCompetitionName == l.Name ? "active" : "")"
                                  @onclick="() => SelectLeague(l.Name)">
                            @l.Name (@l.Count)
                          </button>
                        }
                      </div>
                    }
                  </div>
                }
              </div>
            </div>

            @if (_hydrated)
            {
              <div class="all-toggles">
                <label class="sb-switch">
                  <input type="checkbox"
                         checked="@_prefs.FollowedTeamsOnly"
                         @onchange="OnFollowedOnlyChanged" />
                  <span class="sb-switch-ui"></span>
                </label>
                <span class="all-toggle-label">Followed teams only</span>

                <label class="sb-switch">
                  <input type="checkbox"
                         checked="@_autoSyncEnabled"
                         @onchange="OnAutoSyncChanged" />
                  <span class="sb-switch-ui"></span>
                </label>
                <span class="all-toggle-label">
                  Auto-sync @(_syncing ? "(syncing...)" : "")
                </span>
              </div>
            }
          </div>

          @if (!string.IsNullOrWhiteSpace(_toast))
          {
            <div class="all-toast">@_toast</div>
          }
        </div>
      </div>

      @if (!_hydrated)
      {
        <GlobalSpinner Message="Loading…" />
      }
      else if (_loading)
      {
        <GlobalSpinner Message="Loading matches…" />
      }
      else if (VisibleMatches().Count == 0)
      {
        <p class="small-muted">@(_items.Count > 0 ? "No matches for your followed teams in this range." : "No matches in this range.")</p>
      }
      else
      {
        @if (_viewMode == "day" && (_endDate.DayNumber - _startDate.DayNumber + 1) >= 5)
        {
          <div class="all-date-nav-strip">
            <span class="all-date-nav-title">Jump to date:</span>
            @foreach (var d in GetDatesInRange())
            {
              var count = GetMatchCountForDate(d);
              var isToday = d == DateOnly.FromDateTime(DateTime.Now);
              var isActive = _activeJumpDate == d;
              <button type="button"
                      class="all-date-nav-chip @(isActive ? "active" : "") @(isToday ? "today" : "")"
                      @onclick="() => JumpToDate(d)">
                @d.ToString("ddd") @d.Day @d.ToString("MMM") (@count)
              </button>
            }
          </div>
        }
        @if (_viewMode == "league")
        {
          var byLeague = GroupByCompetition(VisibleMatches());
          @foreach (var comp in byLeague)
          {
            <div class="block">
              <div class="block-title">@comp.Key · @comp.Value.Count matches</div>
              @foreach (var m in comp.Value)
              {
                <div class="am-match">
                  <div class="am-time">@FormatLocalTime(m.UtcDate)</div>
                  <div class="am-team">
                    <img class="am-crest" src="@(string.IsNullOrWhiteSpace(m.HomeTeamCrestUrl) ? "images/teams/placeholder.png" : m.HomeTeamCrestUrl)" alt="@m.HomeTeamName" loading="lazy" referrerpolicy="no-referrer" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;" />
                    <div class="am-name-row">
                      <div class="am-name" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;">@m.HomeTeamName</div>
                      <button class="sb-likebtn @(IsLikedTeam(m.HomeTeamId) ? "liked" : "")" title="Like team" @onclick="() => ToggleLikeTeam(m.HomeTeamId, m.HomeTeamName, m.HomeTeamCrestUrl)" @onclick:stopPropagation="true"><img class="sb-likeimg" src="@TeamLikeIcon(m.HomeTeamId)" alt="like" /></button>
                    </div>
                  </div>
                  <div class="am-team">
                    <img class="am-crest" src="@(string.IsNullOrWhiteSpace(m.AwayTeamCrestUrl) ? "images/teams/placeholder.png" : m.AwayTeamCrestUrl)" alt="@m.AwayTeamName" loading="lazy" referrerpolicy="no-referrer" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;" />
                    <div class="am-name-row">
                      <div class="am-name" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;">@m.AwayTeamName</div>
                      <button class="sb-likebtn @(IsLikedTeam(m.AwayTeamId) ? "liked" : "")" title="Like team" @onclick="() => ToggleLikeTeam(m.AwayTeamId, m.AwayTeamName, m.AwayTeamCrestUrl)" @onclick:stopPropagation="true"><img class="sb-likeimg" src="@TeamLikeIcon(m.AwayTeamId)" alt="like" /></button>
                    </div>
                  </div>
                  <div class="am-right">
                    <div class="am-score"><span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span><span class="sep">:</span><span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span></div>
                    <div class="am-status @(MatchDisplayHelper.IsLiveStatus(m.Status) ? "live" : "")">@m.Status</div>
                  </div>
                </div>
              }
            </div>
          }
        }
        else if (_viewMode == "agenda")
        {
          <div class="block">
            <div class="block-title">Chronological</div>
            @foreach (var m in VisibleMatches())
            {
              <div class="am-match am-match-agenda">
                <div class="am-time">@FormatLocalTime(m.UtcDate)</div>
                <div class="am-agenda-meta">@(m.CompetitionName ?? "Other")</div>
                <div class="am-team">
                  <img class="am-crest" src="@(string.IsNullOrWhiteSpace(m.HomeTeamCrestUrl) ? "images/teams/placeholder.png" : m.HomeTeamCrestUrl)" alt="@m.HomeTeamName" loading="lazy" referrerpolicy="no-referrer" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;" />
                  <div class="am-name-row"><div class="am-name" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;">@m.HomeTeamName</div></div>
                </div>
                <div class="am-team">
                  <img class="am-crest" src="@(string.IsNullOrWhiteSpace(m.AwayTeamCrestUrl) ? "images/teams/placeholder.png" : m.AwayTeamCrestUrl)" alt="@m.AwayTeamName" loading="lazy" referrerpolicy="no-referrer" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;" />
                  <div class="am-name-row"><div class="am-name" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;">@m.AwayTeamName</div></div>
                </div>
                <div class="am-right">
                  @if (!string.IsNullOrWhiteSpace(m.ExternalId)) { <a href="/match/@m.ExternalId" class="am-score am-score-link"><span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span><span class="sep">:</span><span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span></a> } else { <div class="am-score"><span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span><span class="sep">:</span><span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span></div> }
                  <div class="am-status @(MatchDisplayHelper.IsLiveStatus(m.Status) ? "live" : "")">@m.Status</div>
                </div>
              </div>
            }
          </div>
        }
        else
        {
          @foreach (var day in GroupByLocalDay(VisibleMatches()))
          {
            var isExpanded = _expandedDays.Contains(day.Key);
            var leagueCount = day.Value.Select(m => m.CompetitionName ?? "Other").Distinct().Count();
            <div class="block all-day-block" id="day-@day.Key.ToString("yyyy-MM-dd")">
              <div class="block-title all-day-header @(isExpanded ? "expanded" : "")"
                   @onclick="() => ToggleDayExpanded(day.Key)"
                   style="cursor: pointer;">
                <span>@day.Key.ToString("MMM dd, yyyy")</span>
                <span class="small-muted">@day.Value.Count matches · @leagueCount leagues</span>
                <span class="all-day-chevron">@(isExpanded ? "▼" : "▶")</span>
              </div>
              @if (isExpanded)
              {
                @foreach (var comp in GroupByCompetition(day.Value))
                {
                  <div>
                    <div class="am-league-name">@comp.Key</div>

                    @foreach (var m in comp.Value)
                    {
                      <div class="am-match">
                    <div class="am-time">@FormatLocalTime(m.UtcDate)</div>

                    <div class="am-team">
                      <img class="am-crest"
                          src="@(string.IsNullOrWhiteSpace(m.HomeTeamCrestUrl) ? "images/teams/placeholder.png" : m.HomeTeamCrestUrl)"
                          alt="@m.HomeTeamName"
                          loading="lazy"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          onload="this.classList.add('loaded');"
                          onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                          @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")'
                          style="cursor: pointer;" />
                      <div class="am-name-row">
                        <div class="am-name" title="@m.HomeTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;">@m.HomeTeamName</div>
                        <button class="sb-likebtn @(IsLikedTeam(m.HomeTeamId) ? "liked" : "")"
                                title="Like team"
                                @onclick="() => ToggleLikeTeam(m.HomeTeamId, m.HomeTeamName, m.HomeTeamCrestUrl)"
                                @onclick:stopPropagation="true">
                          <img class="sb-likeimg"
                              src="@TeamLikeIcon(m.HomeTeamId)"
                              alt="like" />
                        </button>
                      </div>
                    </div>

                    <div class="am-team">
                      <img class="am-crest"
                          src="@(string.IsNullOrWhiteSpace(m.AwayTeamCrestUrl) ? "images/teams/placeholder.png" : m.AwayTeamCrestUrl)"
                          alt="@m.AwayTeamName"
                          loading="lazy"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          onload="this.classList.add('loaded');"
                          onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                          @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")'
                          style="cursor: pointer;" />
                      <div class="am-name-row">
                        <div class="am-name" title="@m.AwayTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;">@m.AwayTeamName</div>
                        <button class="sb-likebtn @(IsLikedTeam(m.AwayTeamId) ? "liked" : "")"
                                title="Like team"
                                @onclick="() => ToggleLikeTeam(m.AwayTeamId, m.AwayTeamName, m.AwayTeamCrestUrl)"
                                @onclick:stopPropagation="true">
                          <img class="sb-likeimg"
                              src="@TeamLikeIcon(m.AwayTeamId)"
                              alt="like" />
                        </button>
                      </div>
                    </div>

                    <div class="am-right">
                      @if (!string.IsNullOrWhiteSpace(m.ExternalId)) { <a href="/match/@m.ExternalId" class="am-score am-score-link"><span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span><span class="sep">:</span><span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span></a> } else { <div class="am-score"><span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span><span class="sep">:</span><span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span></div> }
                      <div class="am-status @(MatchDisplayHelper.IsLiveStatus(m.Status) ? "live" : "")">@m.Status</div>
                    </div>
                  </div>
                }
              </div>
            }
              }
          </div>
        }
      }
      }
    </div>

    @if (_activeJumpDate != null)
    {
      <button type="button" class="all-back-to-top" @onclick="ScrollBackToTop" title="Back to top">Top</button>
    }
  </div>
</div>

@code {
  private bool _hydrated;
  private bool _loading;
  private bool _syncing;
  private string? _toast;

  private UserPrefs _prefs = new();
  private string _tzId = "America/New_York";
  private DateTime _updatedLocal = DateTime.Now;

  // range (default last 7 days)
  private DateOnly _startDate;
  private DateOnly _endDate;

  // all loaded matches in range
  private readonly List<MatchDto> _items = new();

  // search
  private string _q = "";
  private bool _showSearch;
  private bool _searchLoading;
  private List<SearchResultDto> _results = new();
  private CancellationTokenSource? _searchCts;

  // auto-sync
  private bool _autoSyncEnabled = true;
  private AutoSyncLoop? _autoSyncLoop;

  // league filter
  private string _selectedCompetitionName = ""; // "" = All
  private bool _showLeagueDropdown = false;

  // sticky jump bar: inline filter, view mode, jump to date
  private string _inlineFilter = "";
  private string _viewMode = "day"; // day | league | agenda
  /// <summary>When set, this date is "selected" in Jump to date (one chip active); when null, all chips inactive (e.g. after Back to top).</summary>
  private DateOnly? _activeJumpDate;
  private HashSet<DateOnly> _expandedDays = new();
  private DateOnly? _scrollToDateAfterRender;
  private bool _scrollListenerRegistered;
  private DotNetObjectReference<All>? _dotNetRef;

  // reload
  private CancellationTokenSource? _reloadCts;
  private int _reloadSeq;
  private TimeZoneInfo? _tz;

  protected override void OnInitialized()
  {
    Nav.LocationChanged += OnLocationChanged;
  }

  private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
  {
    if (_hydrated && e.Location.Contains("/all", StringComparison.OrdinalIgnoreCase))
      _ = InvokeAsync(Reload);
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      _tzId = await Tz.GetTimeZoneIdAsync();
      _tz = TimeZoneInfo.FindSystemTimeZoneById(_tzId);
      Api.SetTimeZone(_tzId);

      _prefs = await Prefs.GetAsync();
      _prefs.FollowedTeamIds ??= new();
      EnsureFollowedTeamIdsFromInfo();

      var today = DateOnly.FromDateTime(DateTime.Now);
      _endDate = today;
      _startDate = today.AddDays(-6);

      _hydrated = true;
      StateHasChanged();

      await Reload();

      _autoSyncLoop = new AutoSyncLoop(TimeSpan.FromSeconds(60), async _ => await AutoSyncTick());
      if (_autoSyncEnabled)
        _autoSyncLoop.Start();
      return;
    }

    if (_scrollToDateAfterRender is { } date)
    {
      await JS.InvokeVoidAsync("soccerBlastScrollToDay", "day-" + date.ToString("yyyy-MM-dd"));
      _scrollToDateAfterRender = null;
      await InvokeAsync(StateHasChanged);
    }

    if (_activeJumpDate != null && !_scrollListenerRegistered)
    {
      _scrollListenerRegistered = true;
      _dotNetRef ??= DotNetObjectReference.Create(this);
      await JS.InvokeVoidAsync("soccerBlastRegisterScrollToTopListener", _dotNetRef);
    }
  }

  [JSInvokable]
  public void OnScrolledToTop()
  {
    _activeJumpDate = null;
    _scrollListenerRegistered = false;
    InvokeAsync(StateHasChanged);
  }

  /// <summary>Sync FollowedTeamIds from FollowedTeamsInfo so id-based filter works (e.g. after migration from name-based).</summary>
  private void EnsureFollowedTeamIdsFromInfo()
  {
    if (_prefs.FollowedTeamsInfo == null) return;
    var fromInfo = _prefs.FollowedTeamsInfo.Keys.Where(id => id != 0).ToHashSet();
    if (fromInfo.Count == 0) return;
    var current = _prefs.FollowedTeamIds ??= new List<int>();
    var merged = current.Union(fromInfo).Where(id => id != 0).Distinct().ToList();
    if (merged.Count != current.Count || merged.Except(current).Any())
    {
      _prefs.FollowedTeamIds = merged;
    }
  }

  private async Task AutoSyncTick()
  {
      if (_syncing || !_hydrated || !_autoSyncEnabled) return;

      var from = _startDate;
      var to = _endDate;

      _syncing = true;
      try
      {
          await InvokeAsync(StateHasChanged);

          var today = DateOnly.FromDateTime(DateTime.Now);
          var hotStart = today.AddDays(-1);
          var hotEnd = today.AddDays(1);

          var ensured = await Api.EnsureRangeFreshAsync(hotStart, hotEnd, hotMin: 5, warmMin: 60, coldMin: 0);

          if (ensured?.syncedMatches > 0)
          {
              var rangeMatches = await Api.GetRangeAsync(from, to);
              var inRange = FilterByRequestedRange(rangeMatches, from, to);
              _items.Clear();
              _items.AddRange(inRange);
              _updatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
              //_toast = $"Auto-synced {ensured.syncedMatches} matches.";
          }

          await InvokeAsync(StateHasChanged);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"[AutoSync] Error: {ex.Message}");
    }
    finally
    {
      _syncing = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void OnAutoSyncChanged(ChangeEventArgs e)
  {
    _autoSyncEnabled = e.Value switch
    {
      bool b => b,
      string s => bool.TryParse(s, out var result) && result,
      _ => false
    };

    if (_autoSyncEnabled && _autoSyncLoop != null)
    {
      _autoSyncLoop.Start();
      _toast = "Auto-sync enabled.";
    }
    else if (_autoSyncLoop != null)
    {
      _autoSyncLoop.Stop();
      _toast = "Auto-sync disabled.";
    }

    StateHasChanged();
  }

  public void Dispose()
  {
    Nav.LocationChanged -= OnLocationChanged;
    _autoSyncLoop?.Dispose();
    _reloadCts?.Cancel();
    _reloadCts?.Dispose();
    _searchCts?.Cancel();
    _searchCts?.Dispose();
    _dotNetRef?.Dispose();
  }

  private void OpenSearch() => _showSearch = true;
  private void CloseSearch() => _showSearch = false;

  private async Task OnSearchInput(ChangeEventArgs e)
  {
    _q = e.Value?.ToString() ?? "";
    _showSearch = true;

    _searchCts?.Cancel();
    _searchCts?.Dispose();
    _searchCts = new CancellationTokenSource();
    var token = _searchCts.Token;

    _searchLoading = _q.Trim().Length >= 2;
    StateHasChanged();

    try
    {
      // debounce: wait before calling API to avoid a request on every keystroke
      await Task.Delay(400, token);

      if (_q.Trim().Length < 2)
      {
        _searchLoading = false;
        _results.Clear();
        StateHasChanged();
        return;
      }

      var res = await Api.SearchAsync(_q, 12);
      if (token.IsCancellationRequested) return;

      _results = res;
      _searchLoading = false;
      StateHasChanged();
    }
    catch (TaskCanceledException) { }
    catch
    {
      _searchLoading = false;
      StateHasChanged();
    }
  }

