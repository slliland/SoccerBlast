  /// <summary>Returns "today", "tomorrow", "yesterday", "7d", "30d" if current range matches that preset; otherwise null.</summary>
  private string? PresetKind()
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    var tomorrow = today.AddDays(1);
    var yesterday = today.AddDays(-1);
    var days = (_endDate.DayNumber - _startDate.DayNumber) + 1;
    if (_startDate == today && _endDate == today) return "today";
    if (_startDate == tomorrow && _endDate == tomorrow) return "tomorrow";
    if (_startDate == yesterday && _endDate == yesterday) return "yesterday";
    if (days == 7 && _endDate == today) return "7d";
    if (days == 30 && _endDate == today) return "30d";
    return null;
  }

