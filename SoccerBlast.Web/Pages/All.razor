@page "/all"
@using SoccerBlast.Shared.Contracts
@using SoccerBlast.Web.Services
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer

@inject SoccerApiClient Api
@inject BrowserTimeZone Tz
@inject UserPrefsStore Prefs
@inject NavigationManager Nav
@implements IDisposable

<div class="sb-page all-page" @onclick="CloseOverlays">
  <div class="sb-shell">

    <!-- TOP BAR -->
    <div class="sb-card sb-topbar">
      <div class="sb-brand">
        <img class="sb-logo" src="images/logo/soccer-blast.png" alt="Soccer Blast" />
        <div>Soccer Blast</div>
      </div>

      <div class="sb-tabs">
        <NavLink href="/" Match="NavLinkMatch.All">Live Scores</NavLink>
        <NavLink href="/all" Match="NavLinkMatch.All">All Match</NavLink>
        <NavLink href="/video">Video</NavLink>
        <NavLink href="/news">News</NavLink>
        <NavLink href="/stats">Stats</NavLink>
        <NavLink href="/rankings">Rankings</NavLink>
      </div>

      <div class="sb-search" @onclick:stopPropagation="true">
        <input class="sb-search-input"
               placeholder="Search teams, matches, leagues, news…"
               value="@_q"
               @oninput="OnSearchInput"
               @onfocus="OpenSearch" />

        @if (_showSearch)
        {
          <div class="sb-search-pop">
            @if (_searchLoading)
            {
              <div class="sb-search-row muted">Searching…</div>
            }
            else if (_results.Count == 0 && _q.Trim().Length >= 2)
            {
              <div class="sb-search-row muted">No results</div>
            }
            else
            {
              @foreach (var r in _results)
              {
                <a class="sb-search-row"
                   href="@ResolveHref(r)"
                   target="@(IsExternal(r) ? "_blank" : null)"
                   rel="@(IsExternal(r) ? "noopener noreferrer" : null)"
                   @onclick="CloseSearch"
                   @onclick:stopPropagation="true">
                  <div class="sb-search-title">@r.Title</div>
                  <div class="sb-search-sub"><b>@r.Type</b> · @r.Subtitle</div>
                </a>
              }
            }
          </div>
        }
      </div>

      <NavLink class="sb-avatar" title="Profile" href="/settings" @onclick:stopPropagation="true"></NavLink>
    </div>

    <!-- BODY -->
    <div class="sb-card sb-main">

      <div class="section-head">
        <div class="all-header">
          <h4>All Matches</h4>
          <span class="small-muted">
            @(_hydrated ? $"Updated {_updatedLocal:HH:mm}" : "Loading…")
          </span>
        </div>

        <div class="all-controls">
          <div class="all-row">
            <div class="all-range-group">
              <span class="all-label">Range</span>
              <input type="date" class="sb-dateinput"
                     value="@_startDate.ToString("yyyy-MM-dd")"
                     @onchange="OnStartChanged" />
              <img class="am-arrow-img" src="images/all/arrow-right.png" alt="to" />
              <input type="date" class="sb-dateinput"
                     value="@_endDate.ToString("yyyy-MM-dd")"
                     @onchange="OnEndChanged" />
            </div>

            <div class="all-presets">
              <button class="btn btn-sm @(PresetKind() == "today" ? "active" : "")" @onclick="SetToday">Today</button>
              <button class="btn btn-sm @(PresetKind() == "7d" ? "active" : "")" @onclick="Set7Days">7d</button>
              <button class="btn btn-sm @(PresetKind() == "30d" ? "active" : "")" @onclick="Set30Days">30d</button>
            </div>
          </div>

          <div class="all-row">
            <div class="all-filter-group">
              <span class="all-label">League</span>
              <div class="sb-filter-custom" @onclick:stopPropagation="true">
                <button class="sb-filter-btn" @onclick="ToggleLeagueDropdown">
                  <span class="sb-filter-text">
                    @(string.IsNullOrWhiteSpace(_selectedCompetitionName) ? $"All leagues ({VisibleMatchesRaw().Count})" : $"{_selectedCompetitionName} ({VisibleMatches().Count})")
                  </span>
                  <span class="sb-filter-arrow">▾</span>
                </button>

                @if (_showLeagueDropdown)
                {
                  <div class="sb-filter-menu sb-filter-menu-tiered">
                    <div class="sb-league-filter-inmenu" @onclick:stopPropagation="true">
                      <input type="text"
                             class="sb-league-filter"
                             placeholder="Find league…"
                             value="@_leagueFilter"
                             @oninput="OnLeagueFilterInput" />
                    </div>
                    <button class="sb-filter-option @(string.IsNullOrWhiteSpace(_selectedCompetitionName) ? "active" : "")"
                            @onclick='() => SelectLeague("")'>
                      All leagues (@VisibleMatchesRaw().Count)
                    </button>
                    @foreach (var group in LeagueTierService.GroupOptionsByTier(FilteredLeagueOptions().Select(x => (x.Name, x.Count))))
                    {
                      <div class="sb-filter-tier-group">
                        <div class="sb-filter-tier-title">@group.TierLabel</div>
                        @foreach (var l in group.Leagues)
                        {
                          <button class="sb-filter-option @(_selectedCompetitionName == l.Name ? "active" : "")"
                                  @onclick="() => SelectLeague(l.Name)">
                            @l.Name (@l.Count)
                          </button>
                        }
                      </div>
                    }
                  </div>
                }
              </div>
            </div>

            @if (_hydrated)
            {
              <div class="all-toggles">
                <label class="sb-switch">
                  <input type="checkbox"
                         checked="@_prefs.FollowedTeamsOnly"
                         @onchange="OnFollowedOnlyChanged" />
                  <span class="sb-switch-ui"></span>
                </label>
                <span class="all-toggle-label">Followed teams only</span>

                <label class="sb-switch">
                  <input type="checkbox"
                         checked="@_autoSyncEnabled"
                         @onchange="OnAutoSyncChanged" />
                  <span class="sb-switch-ui"></span>
                </label>
                <span class="all-toggle-label">
                  Auto-sync @(_syncing ? "(syncing...)" : "")
                </span>
              </div>
            }
          </div>

          @if (!string.IsNullOrWhiteSpace(_toast))
          {
            <div class="all-toast">@_toast</div>
          }
        </div>
      </div>

      @if (!_hydrated)
      {
        <GlobalSpinner Message="Loading…" />
      }
      else if (_loading)
      {
        <GlobalSpinner Message="Loading matches…" />
      }
      else if (_items.Count == 0)
      {
        <p class="small-muted">No matches in this range.</p>
      }
      else
      {
        @foreach (var day in GroupByLocalDay(VisibleMatches()))
        {
          <div class="block">
            <div class="block-title">
              <span>@day.Key.ToString("MMM dd, yyyy")</span>
              <span class="small-muted">@($"{day.Value.Count} matches")</span>
            </div>

            @foreach (var comp in GroupByCompetition(day.Value))
            {
              <div>
                <div class="am-league-name">@comp.Key</div>

                @foreach (var m in comp.Value)
                {
                  <div class="am-match">
                    <div class="am-time">@FormatLocalTime(m.UtcDate)</div>

                    <div class="am-team">
                      <img class="am-crest"
                          src="@(string.IsNullOrWhiteSpace(m.HomeTeamCrestUrl) ? "images/teams/placeholder.png" : m.HomeTeamCrestUrl)"
                          alt="@m.HomeTeamName"
                          loading="lazy"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          onload="this.classList.add('loaded');"
                          onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                          @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")'
                          style="cursor: pointer;" />
                      <div class="am-name-row">
                        <div class="am-name" title="@m.HomeTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.HomeTeamId}")' style="cursor: pointer;">@m.HomeTeamName</div>
                        <button class="sb-likebtn @(IsLikedTeam(m.HomeTeamId) ? "liked" : "")"
                                title="Like team"
                                @onclick="() => ToggleLikeTeam(m.HomeTeamId, m.HomeTeamName, m.HomeTeamCrestUrl)"
                                @onclick:stopPropagation="true">
                          <img class="sb-likeimg"
                              src="@TeamLikeIcon(m.HomeTeamId)"
                              alt="like" />
                        </button>
                      </div>
                    </div>

                    <div class="am-team">
                      <img class="am-crest"
                          src="@(string.IsNullOrWhiteSpace(m.AwayTeamCrestUrl) ? "images/teams/placeholder.png" : m.AwayTeamCrestUrl)"
                          alt="@m.AwayTeamName"
                          loading="lazy"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          onload="this.classList.add('loaded');"
                          onerror="this.onerror=null; this.src='images/teams/placeholder.png'; this.classList.add('loaded');"
                          @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")'
                          style="cursor: pointer;" />
                      <div class="am-name-row">
                        <div class="am-name" title="@m.AwayTeamName" @onclick='() => Nav.NavigateTo($"/team/{m.AwayTeamId}")' style="cursor: pointer;">@m.AwayTeamName</div>
                        <button class="sb-likebtn @(IsLikedTeam(m.AwayTeamId) ? "liked" : "")"
                                title="Like team"
                                @onclick="() => ToggleLikeTeam(m.AwayTeamId, m.AwayTeamName, m.AwayTeamCrestUrl)"
                                @onclick:stopPropagation="true">
                          <img class="sb-likeimg"
                              src="@TeamLikeIcon(m.AwayTeamId)"
                              alt="like" />
                        </button>
                      </div>
                    </div>

                    <div class="am-right">
                      <div class="am-score">
                        <span class="num">@MatchDisplayHelper.FormatScore(m.HomeScore)</span>
                        <span class="sep">:</span>
                        <span class="num">@MatchDisplayHelper.FormatScore(m.AwayScore)</span>
                      </div>
                      <div class="am-status @(MatchDisplayHelper.IsLiveStatus(m.Status) ? "live" : "")">@m.Status</div>
                    </div>
                  </div>
                }
              </div>
            }
          </div>
        }
      }
    </div>
  </div>
</div>

@code {
  private bool _hydrated;
  private bool _loading;
  private bool _syncing;
  private string? _toast;

  private UserPrefs _prefs = new();
  private string _tzId = "America/New_York";
  private DateTime _updatedLocal = DateTime.Now;

  // range (default last 7 days)
  private DateOnly _startDate;
  private DateOnly _endDate;

  // all loaded matches in range
  private readonly List<MatchDto> _items = new();

  // search
  private string _q = "";
  private bool _showSearch;
  private bool _searchLoading;
  private List<SearchResultDto> _results = new();
  private CancellationTokenSource? _searchCts;

  // auto-sync
  private bool _autoSyncEnabled = true;
  private AutoSyncLoop? _autoSyncLoop;

  // league filter
  private string _selectedCompetitionName = ""; // "" = All
  private bool _showLeagueDropdown = false;

  // reload
  private CancellationTokenSource? _reloadCts;
  private int _reloadSeq;
  private TimeZoneInfo? _tz;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!firstRender) return;

    _tzId = await Tz.GetTimeZoneIdAsync();
    _tz = TimeZoneInfo.FindSystemTimeZoneById(_tzId);
    Api.SetTimeZone(_tzId);

    _prefs = await Prefs.GetAsync();
    _prefs.FollowedTeamIds ??= new();

    var today = DateOnly.FromDateTime(DateTime.Now);
    _endDate = today;
    _startDate = today.AddDays(-6);

    _hydrated = true;
    StateHasChanged();

    // Initial load: just read from DB; auto-sync loop will refresh in background
    await Reload();

    // Start auto-sync loop (60 seconds)
    _autoSyncLoop = new AutoSyncLoop(TimeSpan.FromSeconds(60), async _ => await AutoSyncTick());
    if (_autoSyncEnabled)
    {
      _autoSyncLoop.Start();
    }
  }

  private async Task AutoSyncTick()
  {
      if (_syncing || !_hydrated || !_autoSyncEnabled) return;

      var from = _startDate;
      var to = _endDate;

      _syncing = true;
      try
      {
          await InvokeAsync(StateHasChanged);

          var today = DateOnly.FromDateTime(DateTime.Now);
          var hotStart = today.AddDays(-1);
          var hotEnd = today.AddDays(1);

          var ensured = await Api.EnsureRangeFreshAsync(hotStart, hotEnd, hotMin: 5, warmMin: 60, coldMin: 0);

          if (ensured?.syncedMatches > 0)
          {
              var rangeMatches = await Api.GetRangeAsync(from, to);
              var inRange = FilterByRequestedRange(rangeMatches, from, to);
              _items.Clear();
              _items.AddRange(inRange);
              _updatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
              //_toast = $"Auto-synced {ensured.syncedMatches} matches.";
          }

          await InvokeAsync(StateHasChanged);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"[AutoSync] Error: {ex.Message}");
    }
    finally
    {
      _syncing = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void OnAutoSyncChanged(ChangeEventArgs e)
  {
    _autoSyncEnabled = e.Value switch
    {
      bool b => b,
      string s => bool.TryParse(s, out var result) && result,
      _ => false
    };

    if (_autoSyncEnabled && _autoSyncLoop != null)
    {
      _autoSyncLoop.Start();
      _toast = "Auto-sync enabled.";
    }
    else if (_autoSyncLoop != null)
    {
      _autoSyncLoop.Stop();
      _toast = "Auto-sync disabled.";
    }

    StateHasChanged();
  }

  public void Dispose()
  {
    _autoSyncLoop?.Dispose();
    _reloadCts?.Cancel();
    _reloadCts?.Dispose();
    _searchCts?.Cancel();
    _searchCts?.Dispose();
  }

  private void OpenSearch() => _showSearch = true;
  private void CloseSearch() => _showSearch = false;

  private async Task OnSearchInput(ChangeEventArgs e)
  {
    _q = e.Value?.ToString() ?? "";
    _showSearch = true;

    _searchCts?.Cancel();
    _searchCts?.Dispose();
    _searchCts = new CancellationTokenSource();
    var token = _searchCts.Token;

    _searchLoading = _q.Trim().Length >= 2;
    StateHasChanged();

    try
    {
      await Task.Delay(250, token);

      if (_q.Trim().Length < 2)
      {
        _searchLoading = false;
        _results.Clear();
        StateHasChanged();
        return;
      }

      var res = await Api.SearchAsync(_q, 12);
      if (token.IsCancellationRequested) return;

      _results = res;
      _searchLoading = false;
      StateHasChanged();
    }
    catch (TaskCanceledException) { }
    catch
    {
      _searchLoading = false;
      StateHasChanged();
    }
  }

  private static bool IsExternal(SearchResultDto r)
    => r.Type == SearchResultType.News && (r.Url?.StartsWith("http", StringComparison.OrdinalIgnoreCase) ?? false);

  private static string ResolveHref(SearchResultDto r)
    => string.IsNullOrWhiteSpace(r.Url) ? "#" : r.Url!;

  private void CloseOverlays()
  {
    _showSearch = false;
    _showLeagueDropdown = false;
  }

  private async Task OnFollowedOnlyChanged(ChangeEventArgs e)
  {
    if (!_hydrated) return;

    _prefs.FollowedTeamsOnly = e.Value switch
    {
      bool b => b,
      string s => bool.TryParse(s, out var r) && r,
      _ => false
    };

    await Prefs.SaveAsync(_prefs);
    _toast = "Saved.";
    StateHasChanged();
  }

  private async Task OnStartChanged(ChangeEventArgs e)
  {
    var s = e.Value?.ToString();
    if (DateOnly.TryParse(s, out var d))
      _startDate = d;

    if (_startDate > _endDate) _endDate = _startDate;

    _toast = null;
    await Reload();
  }

  private async Task OnEndChanged(ChangeEventArgs e)
  {
    var s = e.Value?.ToString();
    if (DateOnly.TryParse(s, out var d))
      _endDate = d;

    if (_endDate < _startDate) _startDate = _endDate;

    _toast = null;
    await Reload();
  }

  private async Task SetToday()
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    _startDate = today;
    _endDate = today;
    await Reload();
  }

  private async Task Set7Days()
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    _endDate = today;
    _startDate = today.AddDays(-6);
    await Reload();
  }

  private async Task Set30Days()
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    _endDate = today;
    _startDate = today.AddDays(-29);
    await Reload();
  }

  /// <summary>Returns "today", "7d", "30d" if current range matches that preset; otherwise null.</summary>
  private string? PresetKind()
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    var days = (_endDate.DayNumber - _startDate.DayNumber) + 1;
    if (_startDate == today && _endDate == today) return "today";
    if (days == 7 && _endDate == today) return "7d";
    if (days == 30 && _endDate == today) return "30d";
    return null;
  }

  /// <summary>Filter matches to those whose local date (in user TZ) falls within [from, to].</summary>
  private List<MatchDto> FilterByRequestedRange(List<MatchDto> matches, DateOnly from, DateOnly to)
  {
    return matches.Where(m =>
    {
      var local = ConvertUtcToLocal(m.UtcDate);
      var d = DateOnly.FromDateTime(local);
      return d >= from && d <= to;
    }).ToList();
  }

  private static bool IntersectsRecent(DateOnly from, DateOnly to, int recentDays = 8)
  {
    var today = DateOnly.FromDateTime(DateTime.Now);
    var recentStart = today.AddDays(-(recentDays - 1));
    return !(to < recentStart || from > today);
  }

  private async Task Reload()
  {
    if (!_hydrated) return;

    // snapshot current range
    var from = _startDate;
    var to = _endDate;

    _reloadCts?.Cancel();
    _reloadCts?.Dispose();
    _reloadCts = new CancellationTokenSource();
    var ct = _reloadCts.Token;

    var mySeq = ++_reloadSeq;

    _loading = true;
    _selectedCompetitionName = "";
    StateHasChanged();

    try
    {
      EnsureRangeResult? ensured = null;

      // only ensure when range touches recent window
      if (IntersectsRecent(from, to, recentDays: 8))
      {
        ensured = await Api.EnsureRangeFreshAsync(
          from, to,
          hotMin: 5,
          warmMin: 60,
          coldMin: 43200,
          ct: ct
        );
      }

      // read from DB
      var rangeMatches = await Api.GetRangeAsync(from, to, competitionId: null, ct: ct);

      // ignore stale result
      if (ct.IsCancellationRequested || mySeq != _reloadSeq) return;

      var inRange = FilterByRequestedRange(rangeMatches, from, to);
      _items.Clear();
      _items.AddRange(inRange);

      _updatedLocal = ConvertUtcToLocal(DateTime.UtcNow);
      var daySpan = (to.DayNumber - from.DayNumber) + 1;

      //if (ensured?.syncedMatches > 0)
      //  _toast = $"Updated {_items.Count} matches ({daySpan} days) — synced {ensured.syncedMatches}.";
      //else
       // _toast = $"Loaded {_items.Count} matches ({daySpan} days).";
    }
    catch (OperationCanceledException) { }
    catch (Exception ex)
    {
      if (!ct.IsCancellationRequested)
        _toast = $"Load failed: {ex.Message}";
    }
    finally
    {
      if (!ct.IsCancellationRequested)
      {
        _loading = false;
        StateHasChanged();
      }
    }
  }


  private sealed record LeagueOpt(string Name, int Count);

  private string _leagueFilter = "";

  private List<LeagueOpt> LeagueOptions()
  {
    return VisibleMatchesRaw()
        .GroupBy(m => m.CompetitionName ?? "Other")
        .Select(g => new LeagueOpt(g.Key, g.Count()))
        .OrderByDescending(x => x.Count)
        .ThenBy(x => x.Name)
        .ToList();
  }

  private List<LeagueOpt> FilteredLeagueOptions()
  {
    var list = LeagueOptions();
    if (string.IsNullOrWhiteSpace(_leagueFilter)) return list;
    return list
        .Where(o => (o.Name ?? "").Contains(_leagueFilter, StringComparison.OrdinalIgnoreCase))
        .ToList();
  }

  private void OnLeagueFilterInput(ChangeEventArgs e)
  {
    _leagueFilter = (e.Value?.ToString() ?? "").Trim();
    StateHasChanged();
  }

  private void ToggleLeagueDropdown()
  {
    _showLeagueDropdown = !_showLeagueDropdown;
  }

  private void SelectLeague(string leagueName)
  {
    _selectedCompetitionName = leagueName;
    _showLeagueDropdown = false;
    StateHasChanged();
  }

  private IEnumerable<MatchDto> ApplyBaseFilters(IEnumerable<MatchDto> src)
  {
      if (_prefs.FollowedTeamsOnly && _prefs.FollowedTeamIds.Count > 0)
          src = src.Where(m => _prefs.FollowedTeamIds.Contains(m.HomeTeamId) ||
                              _prefs.FollowedTeamIds.Contains(m.AwayTeamId));
      return src;
  }

  private List<MatchDto> VisibleMatchesRaw()
    => ApplyBaseFilters(_items).OrderBy(m => m.UtcDate).ToList();

  private List<MatchDto> VisibleMatches()
  {
      var q = ApplyBaseFilters(_items);

      if (!string.IsNullOrWhiteSpace(_selectedCompetitionName))
          q = q.Where(m => string.Equals(m.CompetitionName ?? "Other", _selectedCompetitionName, StringComparison.Ordinal));

      return q.OrderBy(m => m.UtcDate).ToList();
  }

  private Dictionary<DateOnly, List<MatchDto>> GroupByLocalDay(List<MatchDto> matches)
  {
      return matches
        .GroupBy(m => DateOnly.FromDateTime(ConvertUtcToLocal(m.UtcDate)))
        .OrderByDescending(g => g.Key)
        .ToDictionary(g => g.Key, g => g.ToList());
  }

  private static Dictionary<string, List<MatchDto>> GroupByCompetition(List<MatchDto> matches)
  {
    return matches
      .GroupBy(m => m.CompetitionName ?? "Other")
      .OrderBy(g => g.Key)
      .ToDictionary(g => g.Key, g => g.ToList());
  }

  private DateTime ConvertUtcToLocal(DateTime utc)
    => TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), _tz!);


  private string FormatLocalTime(DateTime utcDate)
    => ConvertUtcToLocal(utcDate).ToString("HH:mm");

  // Team like/unlike functionality
  private bool IsLikedTeam(int teamId) 
    => TeamLikeHelper.IsLiked(teamId, _prefs.FollowedTeamIds);

  private string TeamLikeIcon(int teamId)
    => TeamLikeHelper.GetLikeIconPath(teamId, _prefs.FollowedTeamIds);

  private async Task ToggleLikeTeam(int teamId, string teamName, string? teamCrestUrl)
  {
    await TeamLikeHelper.ToggleLikeAsync(teamId, teamName, teamCrestUrl, _prefs.FollowedTeamIds, Prefs, async () =>
    {
      await InvokeAsync(StateHasChanged);
    });
  }
}
