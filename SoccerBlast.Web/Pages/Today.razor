@page "/today"
@using SoccerBlast.Shared.Contracts
@inject IHttpClientFactory HttpClientFactory

<h3>Today's Matches</h3>

@if (_matches == null)
{
    <p>Loading...</p>
}
else if (_matches.Count == 0)
{
    <p>No matches today.</p>
}
else
{
    <ul>
        @foreach (var m in _matches)
        {
            <li>
                @m.UtcDate.ToString("HH:mm") - @m.CompetitionName:
                @m.HomeTeamName (@m.HomeScore) vs @m.AwayTeamName (@m.AwayScore)
                [@m.Status]
            </li>
        }
    </ul>
}

@code {
    private List<MatchDto>? _matches;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("SoccerApi");
        _matches = await client.GetFromJsonAsync<List<MatchDto>>("api/matches/today");
    }
}
