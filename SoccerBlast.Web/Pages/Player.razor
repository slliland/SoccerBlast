                    <button type="button" class="team-viewbtn @(_playerMediaView == "render" ? "active" : "")" @onclick='() => _playerMediaView = "render"'>Render</button>
                  </div>
                  <div class="player-media-featured">
                    <img src="@(GetPlayerFeaturedMediaUrl() ?? "/images/icons/soccer-player.png")" alt="@_player.Name" class="player-media-cutout" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null; this.src='/images/icons/soccer-player.png';" />
                  </div>
                </div>
              }
              @if (_player.FanartUrls != null && _player.FanartUrls.Count > 0)
              {
                <div class="team-section-block">
                  <h3 class="team-block-title">Gallery</h3>
                  <div class="sb-gallery-grid">
                    @for (var i = 0; i < _player.FanartUrls.Count; i++)
                    {
                      var url = _player.FanartUrls[i];
                      <img src="@url"
                           alt="@_player.Name gallery"
                           class="sb-gallery-img"
                           loading="lazy"
                           referrerpolicy="no-referrer"
                           onerror="this.style.display='none';"
                           @onclick="() => OpenPlayerGallery(i)" />
                    }
                  </div>
                </div>
              }
              @if (HasAnyLink())
              {
                <div class="team-section-block">
                  <h3 class="team-block-title">Links</h3>
                  <div class="player-links-list">
                    @if (!string.IsNullOrWhiteSpace(_player.InstagramUrl))
                    {
                      <a href="@NormalizeLink(_player.InstagramUrl, "instagram.com")" target="_blank" rel="noopener noreferrer" class="player-link-item">
                        <img src="/images/teams/media/instagram.png" alt="Instagram" class="player-link-icon-img" loading="lazy" />
                        <span>Instagram</span>
                      </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.FacebookUrl))
                    {
                      <a href="@NormalizeLink(_player.FacebookUrl, "facebook.com")" target="_blank" rel="noopener noreferrer" class="player-link-item">
                        <img src="/images/teams/media/facebook.png" alt="Facebook" class="player-link-icon-img" loading="lazy" />
                        <span>Facebook</span>
                      </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.TwitterUrl))
                    {
                      <a href="@NormalizeLink(_player.TwitterUrl, "twitter.com")" target="_blank" rel="noopener noreferrer" class="player-link-item">
                        <img src="/images/teams/media/twitter.png" alt="Twitter / X" class="player-link-icon-img" loading="lazy" />
                        <span>Twitter / X</span>
                      </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.YoutubeUrl))
                    {
                      <a href="@NormalizeLink(_player.YoutubeUrl, "youtube.com")" target="_blank" rel="noopener noreferrer" class="player-link-item">
                        <img src="/images/teams/media/youtube.png" alt="YouTube" class="player-link-icon-img" loading="lazy" />
                        <span>YouTube</span>
                      </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.WebsiteUrl))
                    {
                      <a href="@NormalizeLink(_player.WebsiteUrl, null)" target="_blank" rel="noopener noreferrer" class="player-link-item">
                        <img src="/images/teams/media.png" alt="Website" class="player-link-icon-img" loading="lazy" />
                        <span>Website</span>
                      </a>
                    }
                  </div>
                </div>
              }
            }
            else
            {
              <p class="player-no-enrichment small-muted">No media or links available.</p>
            }
          </div>
        }
      </div>
    </div>
  }

  @if (_playerGalleryOpen && _playerGalleryUrls != null && _playerGalleryUrls.Count > 0)
  {
    <div class="sb-gallery-overlay" @onclick="ClosePlayerGallery">
      <div class="sb-gallery-modal" @onclick:stopPropagation="true">
        <button type="button" class="sb-gallery-close" @onclick="ClosePlayerGallery" aria-label="Close gallery">×</button>
        <button type="button" class="sb-gallery-nav sb-gallery-nav-prev" @onclick="PrevPlayerGallery" aria-label="Previous">‹</button>
        <img src="@_playerGalleryUrls[_playerGalleryIndex]" alt="Gallery" class="sb-gallery-img" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.display='none';" />
        <button type="button" class="sb-gallery-nav sb-gallery-nav-next" @onclick="NextPlayerGallery" aria-label="Next">›</button>
      </div>
    </div>
  }
</div>

@code {
  [Parameter] public string? Id { get; set; }

  private string _activeTab = "profile";
  private bool _loading = true;
  private PlayerDetailDto? _player;
  private List<PlayerContractDto>? _contracts;
  private List<PlayerFormerTeamDto>? _formerTeams;
  private List<PlayerHonourDto>? _honours;
  private List<PlayerMilestoneDto>? _milestones;
  private string _honourFilter = "all";
  private string _honourSort = "prestige";
  private bool _honourSortOpen;
  private string _honourView = "cabinet";
  private HashSet<string> _honoursCollapsed = new(StringComparer.OrdinalIgnoreCase) { "bestxi" };
  private string? _honoursExpandedCard;
  private string _milestoneFilter = "all";
  private string _milestoneView = "timeline";
  private bool _milestoneSortOpen;
  private string _playerMediaView = "cutout";

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _player = null;
    _contracts = null;
    _formerTeams = null;
    _honours = null;
    _milestones = null;

    try
    {
      if (string.IsNullOrWhiteSpace(Id)) return;
      using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
      _player = await Api.GetPlayerAsync(Id!, cts.Token);
      if (_player == null) return;

      var pid = Id!.Trim();
      try
      {
        var loadContracts = Api.GetPlayerContractsAsync(pid, cts.Token);
        var loadFormerTeams = Api.GetPlayerFormerTeamsAsync(pid, cts.Token);
        var loadHonours = Api.GetPlayerHonoursAsync(pid, cts.Token);
        var loadMilestones = Api.GetPlayerMilestonesAsync(pid, cts.Token);
        await Task.WhenAll(loadContracts, loadFormerTeams, loadHonours, loadMilestones);

        _contracts = await loadContracts;
        _formerTeams = await loadFormerTeams;
        _honours = await loadHonours;
        _milestones = await loadMilestones;
      }
      catch
      {
        _contracts = new List<PlayerContractDto>();
        _formerTeams = new List<PlayerFormerTeamDto>();
        _honours = new List<PlayerHonourDto>();
        _milestones = new List<PlayerMilestoneDto>();
      }
    }
    catch
    {
      _player = null;
    }
    finally
    {
      _loading = false;
    }
  }

  private bool HasAnyEnrichment()
  {
    return (_contracts?.Count ?? 0) > 0 || (_formerTeams?.Count ?? 0) > 0 ||
           (_honours?.Count ?? 0) > 0 || (_milestones?.Count ?? 0) > 0 || HasAnyLink();
  }

  private bool HasAnyLink()
  {
    return _player != null && (
      !string.IsNullOrWhiteSpace(_player.InstagramUrl) ||
      !string.IsNullOrWhiteSpace(_player.FacebookUrl) ||
      !string.IsNullOrWhiteSpace(_player.TwitterUrl) ||
      !string.IsNullOrWhiteSpace(_player.YoutubeUrl) ||
      !string.IsNullOrWhiteSpace(_player.WebsiteUrl));
  }

  private static bool IsPlayerStatusActive(string? status)
  {
    return !string.IsNullOrWhiteSpace(status) && status.Trim().Equals("Active", StringComparison.OrdinalIgnoreCase);
  }

  private static string FormatBornWithAge(DateTime? dateOfBirth)
  {
    if (dateOfBirth == null) return "";
    var dob = dateOfBirth.Value;
    var s = dob.ToString("yyyy-MM-dd");
    var today = DateTime.Today;
    var age = today.Year - dob.Year;
    if (dob.Date > today.AddYears(-age)) age--;
    if (age >= 0 && age <= 120) return $"{s} ({age} years)";
    return s;
  }

  private string? GetPlayerFeaturedMediaUrl()
  {
    if (_player == null) return null;
    return _playerMediaView switch
    {
      "cartoon" => _player.CartoonUrl ?? _player.CutoutUrl ?? _player.RenderUrl,
      "render" => _player.RenderUrl ?? _player.CutoutUrl ?? _player.CartoonUrl,
      _ => _player.CutoutUrl ?? _player.CartoonUrl ?? _player.RenderUrl
    };
  }

  private bool HasPlayerFeaturedMedia()
  {
    return _player != null && (!string.IsNullOrWhiteSpace(_player.CutoutUrl) || !string.IsNullOrWhiteSpace(_player.CartoonUrl) || !string.IsNullOrWhiteSpace(_player.RenderUrl));
  }

  private bool _playerGalleryOpen;
  private int _playerGalleryIndex;
  private List<string>? _playerGalleryUrls;

  private void OpenPlayerGallery(int index)
  {
    if (_player?.FanartUrls == null || _player.FanartUrls.Count == 0) return;
    _playerGalleryUrls = _player.FanartUrls;
    _playerGalleryIndex = Math.Clamp(index, 0, _player.FanartUrls.Count - 1);
    _playerGalleryOpen = true;
  }

  private void ClosePlayerGallery()
  {
    _playerGalleryOpen = false;
  }

  private void NextPlayerGallery()
  {
    if (_playerGalleryUrls == null || _playerGalleryUrls.Count == 0) return;
    _playerGalleryIndex = (_playerGalleryIndex + 1) % _playerGalleryUrls.Count;
  }

  private void PrevPlayerGallery()
  {
    if (_playerGalleryUrls == null || _playerGalleryUrls.Count == 0) return;
    _playerGalleryIndex = (_playerGalleryIndex - 1 + _playerGalleryUrls.Count) % _playerGalleryUrls.Count;
  }

  private static string FormatMilestoneDate(string? dateStr)
  {
    if (string.IsNullOrWhiteSpace(dateStr)) return "";
    var s = dateStr.Trim();
    if (DateTime.TryParse(s, out var d)) return d.ToString("MMM d, yyyy");
    return s;
  }

  private static string NormalizeLink(string url, string? ensureDomain)
  {
    var u = url.Trim();
    if (string.IsNullOrWhiteSpace(u)) return "#";
    if (!u.StartsWith("http://", StringComparison.OrdinalIgnoreCase) && !u.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
      u = "https://" + u;
    if (!string.IsNullOrWhiteSpace(ensureDomain) && !u.Contains(ensureDomain, StringComparison.OrdinalIgnoreCase))
      u = "https://" + ensureDomain + "/" + u.TrimStart('/');
    return u;
  }

  private async Task GoBack()
  {
    try
    {
      await JSRuntime.InvokeVoidAsync("soccerBlastBack");
    }
    catch
    {
      Nav.NavigateTo("/", forceLoad: false);
    }
  }

  private sealed record CareerEntry(
    string? TeamId,
    string? TeamName,
    string? TeamBadge,
    string? YearStart,
    string? YearEnd,
    string? Joined,
    string? Departed,
    double DurationYears,
    bool IsNational,
    bool IsYouth,
    bool IsReturn,
    string? ContractType,
    DateTime? ParsedJoined
  );

  private sealed record CareerSummary(
    int? CareerStartYear,
    int ClubStints,
    int UniqueClubs,
    string? LongestSpell,
    string? NationalTeamSpan
  );

  private List<CareerEntry> GetCareerEntriesOrderedByJoined()
  {
    if (_formerTeams == null || _formerTeams.Count == 0 || _player == null) return new List<CareerEntry>();
    var nationality = _player.Nationality?.Trim() ?? "";
    var list = new List<CareerEntry>();
    var seenTeamNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    foreach (var t in _formerTeams)
    {
      var joined = ParseFlexibleDate(t.Joined ?? t.YearStart);
      var departed = ParseFlexibleDate(t.Departed ?? t.YearEnd);
      var years = 0.0;
      if (joined.HasValue && departed.HasValue) years = (departed.Value - joined.Value).TotalDays / 365.25;
      else if (joined.HasValue && !departed.HasValue) years = (DateTime.UtcNow - joined.Value).TotalDays / 365.25;
      var teamName = t.TeamName?.Trim() ?? "";
      var isNational = !string.IsNullOrWhiteSpace(nationality) && !string.IsNullOrWhiteSpace(teamName) &&
        (string.Equals(teamName, nationality, StringComparison.OrdinalIgnoreCase) || nationality.Contains(teamName, StringComparison.OrdinalIgnoreCase) || teamName.Contains(nationality, StringComparison.OrdinalIgnoreCase));
      var isYouth = string.Equals(t.ContractType, "Youth", StringComparison.OrdinalIgnoreCase) ||
        (teamName.Contains("Youth", StringComparison.OrdinalIgnoreCase));
      var isReturn = !string.IsNullOrWhiteSpace(teamName) && seenTeamNames.Contains(teamName);
      if (!string.IsNullOrWhiteSpace(teamName)) seenTeamNames.Add(teamName);
      list.Add(new CareerEntry(
        t.TeamId,
        t.TeamName,
        t.TeamBadge,
        t.YearStart,
        t.YearEnd,
        t.Joined,
        t.Departed,
        Math.Round(years, 1),
        isNational,
        isYouth,
        isReturn,
        t.ContractType,
        joined
      ));
    }
    return list.OrderBy(e => e.ParsedJoined ?? DateTime.MaxValue).ToList();
  }

  private static DateTime? ParseFlexibleDate(string? s)
  {
    if (string.IsNullOrWhiteSpace(s)) return null;
    s = s.Trim();
    if (DateTime.TryParse(s, out var d)) return d;
    if (int.TryParse(s, out var y) && y >= 1900 && y <= 2100) return new DateTime(y, 7, 1);
    if (s.Length >= 4 && int.TryParse(s.Substring(0, 4), out y) && y >= 1900 && y <= 2100) return new DateTime(y, 7, 1);
    return null;
  }

  private CareerSummary GetCareerSummary(List<CareerEntry> entries)
  {
    if (entries == null || entries.Count == 0) return new CareerSummary(null, 0, 0, null, null);
    var clubs = entries.Where(e => !e.IsNational).ToList();
    var startYear = entries.Min(e => e.ParsedJoined?.Year);
    var clubStints = clubs.Count;
    var uniqueClubs = clubs.Select(e => e.TeamName ?? "").Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    var longest = clubs.OrderByDescending(e => e.DurationYears).FirstOrDefault();
    var longestSpell = longest != null && longest.DurationYears > 0 ? $"{longest.TeamName} ({FormatDuration(longest.DurationYears)})" : null;
    var national = entries.Where(e => e.IsNational).ToList();
    var nationalSpan = national.Count > 0
      ? $"{national.Min(e => e.YearStart ?? e.Joined ?? "?")}–{national.Max(e => e.YearEnd ?? e.Departed ?? "?")}"
      : null;
    return new CareerSummary(startYear, clubStints, uniqueClubs, longestSpell, nationalSpan);
  }

  private static string FormatDuration(double years)
  {
    if (years < 1) return "<1y";
    if (years < 2) return "1y";
    return $"{(int)years}y";
  }

  private sealed record HonourGroup(
    string DisplayName,
    string Category,
    int Count,
    List<string> SeasonChips,
    string? FirstWonYear,
    string? LastWonYear,
    int? SpanYears,
    bool IsPrestige,
    bool IsRecurring,
    string? IconUrl,
    string? Competition
  );

  private sealed record HonoursSummary(
    int TotalCount,
    int UniqueTypes,
    int TeamCount,
    int IndividualCount,
    string? MostFrequent,
    string? PeakPeriod
  );

  private static string NormalizeHonourKey(string? name)
  {
    if (string.IsNullOrWhiteSpace(name)) return "";
    var s = name.Trim();
    s = System.Text.RegularExpressions.Regex.Replace(s, @"\s+", " ");
    return s;
  }

  private static string NormalizeSeasonChip(string? season)
  {
    if (string.IsNullOrWhiteSpace(season)) return "";
    var s = season.Trim();
    var m = System.Text.RegularExpressions.Regex.Match(s, @"(\d{4})[-–](\d{2,4})");
    if (m.Success && int.TryParse(m.Groups[1].Value, out var y1) && int.TryParse(m.Groups[2].Value, out var y2))
    {
      if (y2 >= 1000) y2 %= 100;
      return $"{y1}–{y2:D2}";
    }
    if (System.Text.RegularExpressions.Regex.IsMatch(s, @"^\d{4}$")) return s;
    return s;
  }

  private static string GetHonourCategory(string displayName, string? competition)
  {
    var n = (displayName + " " + (competition ?? "")).ToLowerInvariant();
    if (n.Contains("ballon") || n.Contains("ballon d'or") || n.Contains("fifa the best") || n.Contains("player of the year") || n.Contains("pfa") || n.Contains("pichichi") || n.Contains("golden boot") || n.Contains("capocannoniere") || n.Contains("golden shoe") || n.Contains("puskás") || n.Contains("puskas")) return "individual";
    if (n.Contains("top scorer") || n.Contains("golden boot") || n.Contains("pichichi") || n.Contains("capocannoniere") || n.Contains("golden shoe") || n.Contains("euro top")) return "scorer";
    if (n.Contains("team of the year") || n.Contains("world xi") || n.Contains("fifpro") || n.Contains("best xi") || n.Contains("uefa team") || n.Contains("toty")) return "bestxi";
    if (n.Contains("bravo") || n.Contains("youth") || n.Contains("young")) return "youth";
    return "team";
  }

  private static bool IsPrestigeHonour(string displayName)
  {
    var n = displayName.ToLowerInvariant();
    return n.Contains("ballon") || n.Contains("champions league") || n.Contains("euro ") || n.Contains("world cup") || n.Contains("european championship");
  }

  private static bool IsRecurringHonour(string displayName)
  {
    var n = displayName.ToLowerInvariant();
    return n.Contains("team of the year") || n.Contains("world xi") || n.Contains("fifpro") || n.Contains("best xi");
  }

  private List<HonourGroup> GetHonourGroups()
  {
    if (_honours == null || _honours.Count == 0) return new List<HonourGroup>();
    var dict = new Dictionary<string, List<PlayerHonourDto>>(StringComparer.OrdinalIgnoreCase);
    foreach (var h in _honours)
    {
      var name = (h.Title ?? h.Honour ?? "").Trim();
      if (string.IsNullOrWhiteSpace(name)) continue;
      var key = NormalizeHonourKey(name);
      if (string.IsNullOrWhiteSpace(key)) continue;
      if (!dict.ContainsKey(key)) dict[key] = new List<PlayerHonourDto>();
      dict[key].Add(h);
    }
    var list = new List<HonourGroup>();
    foreach (var kv in dict)
    {
      var entries = kv.Value;
      var first = entries[0];
      var displayName = first.Title ?? first.Honour ?? kv.Key;
      var competition = entries.Select(e => e.Competition).FirstOrDefault(c => !string.IsNullOrWhiteSpace(c));
      var category = GetHonourCategory(displayName, competition);
      var seasons = entries.Select(e => NormalizeSeasonChip(e.Season ?? e.Competition)).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct().OrderBy(s => s).ToList();
      if (seasons.Count == 0) seasons.Add("—");
      var years = entries.Select(e => e.Season).Where(s => !string.IsNullOrWhiteSpace(s)).Select(s => { var m = System.Text.RegularExpressions.Regex.Match(s, @"(\d{4})"); return m.Success ? m.Groups[1].Value : null; }).Where(x => x != null).Select(x => x!).ToList();
      var firstYear = years.Count > 0 ? years.Min() : null;
      var lastYear = years.Count > 0 ? years.Max() : null;
      int? span = null;
      if (firstYear != null && lastYear != null && int.TryParse(firstYear, out var fy) && int.TryParse(lastYear, out var ly)) span = ly - fy;
      var iconUrl = first.TrophyUrl ?? first.HonourLogoUrl;
      list.Add(new HonourGroup(displayName, category, entries.Count, seasons, firstYear, lastYear, span, IsPrestigeHonour(displayName), IsRecurringHonour(displayName), iconUrl, competition));
    }
    return list;
  }

  private HonoursSummary GetHonoursSummary(List<HonourGroup> groups)
  {
    if (groups == null || groups.Count == 0) return new HonoursSummary(0, 0, 0, 0, null, null);
    var total = _honours?.Count ?? 0;
    var unique = groups.Count;
    var team = groups.Count(g => g.Category == "team");
    var individual = groups.Count(g => g.Category == "individual" || g.Category == "scorer");
    var mostFreq = groups.OrderByDescending(g => g.Count).FirstOrDefault();
    var mostFrequent = mostFreq != null ? $"{mostFreq.DisplayName} ({mostFreq.Count})" : null;
    var allYears = new List<string>();
    foreach (var g in groups)
      foreach (var chip in g.SeasonChips)
      { var m = System.Text.RegularExpressions.Regex.Match(chip ?? "", @"(\d{4})"); if (m.Success) allYears.Add(m.Groups[1].Value); }
    var peakPeriod = allYears.Count > 0 ? $"{allYears.Min()}–{allYears.Max()}" : null;
    return new HonoursSummary(total, unique, team, individual, mostFrequent, peakPeriod);
  }

  private static int HonourCategoryOrder(string cat)
  {
    return cat switch { "team" => 0, "individual" => 1, "scorer" => 2, "bestxi" => 3, "youth" => 4, _ => 5 };
  }

  private static string HonourCategoryLabel(string cat)
  {
    return cat switch { "team" => "Team Trophies", "individual" => "Individual Awards", "scorer" => "Top Scorer Awards", "bestxi" => "Team of the Year / Best XI", "youth" => "Youth / Early Career", _ => cat };
  }

  private List<HonourGroup> GetFilteredAndSortedHonourGroups(List<HonourGroup> groups)
  {
    if (groups == null) return new List<HonourGroup>();
    var list = groups.AsEnumerable();
    if (_honourFilter != "all")
      list = list.Where(g => string.Equals(g.Category, _honourFilter, StringComparison.OrdinalIgnoreCase));
    list = _honourSort switch
    {
      "count" => list.OrderByDescending(g => g.Count).ThenBy(g => g.DisplayName),
      "latest" => list.OrderByDescending(g => g.LastWonYear ?? "").ThenBy(g => g.DisplayName),
      "alpha" => list.OrderBy(g => g.DisplayName),
      _ => list.OrderByDescending(g => g.IsPrestige ? 1 : 0).ThenByDescending(g => g.Count).ThenBy(g => g.DisplayName)
    };
    return list.ToList();
  }

  private List<(string SeasonDisplay, string Name, string? Competition)> GetHonoursTimelineList()
  {
    if (_honours == null || _honours.Count == 0) return new List<(string, string, string?)>();
    var list = _honours
      .Select(h =>
      {
        var name = h.Title ?? h.Honour ?? "—";
        var cat = GetHonourCategory(name, h.Competition);
        return (SeasonDisplay: NormalizeSeasonChip(h.Season ?? ""), Name: name, h.Competition, Category: cat);
      })
      .Where(x => !string.IsNullOrWhiteSpace(x.Name));
    if (_honourFilter != "all")
      list = list.Where(x => string.Equals(x.Category, _honourFilter, StringComparison.OrdinalIgnoreCase));
    return list.OrderBy(x => x.SeasonDisplay).Select(x => (x.SeasonDisplay, x.Name, x.Competition)).ToList();
  }

  private void ToggleHonoursCategory(string category)
  {
    var next = new HashSet<string>(_honoursCollapsed, StringComparer.OrdinalIgnoreCase);
    if (next.Contains(category)) next.Remove(category); else next.Add(category);
    _honoursCollapsed = next;
  }

  private sealed record MilestoneItem(
    string Title,
    string? Team,
    string? BadgeUrl,
    string? IconUrl,
    string DateDisplay,
    string Category,
    string CategoryLabel,
    int Year,
    DateTime? SortDate,
    bool IsFeatured,
    string? Subtitle
  );

  private sealed record MilestonesSummary(int Total, int HatTricks, int Records, int Tournament, string? MostRecent);

  private static string GetMilestoneCategory(string? name, string? stat)
  {
    var n = ((name ?? "") + " " + (stat ?? "")).ToLowerInvariant();
    if (n.Contains("hat-trick") || n.Contains("hat trick")) return "hattrick";
    if (n.Contains("player of the match") || n.Contains("potm") || n.Contains("man of the match")) return "potm";
    if (n.Contains("player of the month") || n.Contains("goal of the month") || n.Contains("goal of the moment")) return "monthly";
    if (n.Contains("dream team") || n.Contains("best xi") || n.Contains("team of the")) return "dreamteam";
    if (n.Contains("500") || n.Contains("750") || n.Contains("career goal") || n.Contains("landmark") || n.Contains("record")) return "record";
    if (n.Contains("world cup") || n.Contains("euro ") || n.Contains("champions league") || n.Contains("tournament")) return "tournament";
    if (n.Contains("league") || n.Contains("premier league") || n.Contains("la liga")) return "league";
    return "other";
  }

  private static string GetMilestoneCategoryLabel(string category)
  {
    return category switch { "hattrick" => "Hat-Trick", "potm" => "Player of the Match", "monthly" => "Monthly Award", "dreamteam" => "Dream Team", "record" => "Record", "tournament" => "Tournament", "league" => "League Award", _ => "Milestone" };
  }

  private static bool IsFeaturedMilestone(string category, string? name)
  {
    var n = (name ?? "").ToLowerInvariant();
    if (category == "record") return true;
    if (category == "tournament" && (n.Contains("hat-trick") || n.Contains("dream team"))) return true;
    if (n.Contains("500 career") || n.Contains("750 career")) return true;
    return false;
  }

  private List<MilestoneItem> GetMilestoneItems()
  {
    if (_milestones == null || _milestones.Count == 0) return new List<MilestoneItem>();
    var list = new List<MilestoneItem>();
    foreach (var m in _milestones)
    {
      var title = m.Name ?? m.Description ?? "—";
      if (string.IsNullOrWhiteSpace(title)) continue;
      var category = GetMilestoneCategory(title, m.Stat);
      var categoryLabel = GetMilestoneCategoryLabel(category);
      var dateDisplay = FormatMilestoneDate(m.DateMilestone ?? m.Season);
      if (string.IsNullOrWhiteSpace(dateDisplay)) dateDisplay = m.Season ?? "—";
      var (year, sortDate) = ParseMilestoneYear(m.DateMilestone ?? m.Season);
      var isFeatured = IsFeaturedMilestone(category, title);
      var subtitle = isFeatured && (category == "record" || category == "tournament") ? (category == "record" ? "Career landmark" : "Tournament landmark") : null;
      list.Add(new MilestoneItem(title, m.Team, m.BadgeUrl, m.MilestoneLogoUrl ?? m.BadgeUrl, dateDisplay, category, categoryLabel, year, sortDate, isFeatured, subtitle));
    }
    return list.OrderByDescending(x => x.SortDate ?? DateTime.MinValue).ToList();
  }

  private static (int year, DateTime? sortDate) ParseMilestoneYear(string? s)
  {
    if (string.IsNullOrWhiteSpace(s)) return (0, null);
    var m = System.Text.RegularExpressions.Regex.Match(s.Trim(), @"(\d{4})");
    if (m.Success && int.TryParse(m.Groups[1].Value, out var y)) return (y, new DateTime(y, 6, 1));
    if (DateTime.TryParse(s, out var d)) return (d.Year, d);
    return (0, null);
  }

  private MilestonesSummary GetMilestonesSummary(List<MilestoneItem> items)
  {
    if (items == null || items.Count == 0) return new MilestonesSummary(0, 0, 0, 0, null);
    var hatTricks = items.Count(i => i.Category == "hattrick");
    var records = items.Count(i => i.Category == "record");
    var tournament = items.Count(i => i.Category == "tournament");
    var mostRecent = items.Where(i => i.SortDate.HasValue).OrderByDescending(i => i.SortDate).FirstOrDefault();
    return new MilestonesSummary(items.Count, hatTricks, records, tournament, mostRecent?.DateDisplay);
  }

  private List<string> GetMilestoneTeams()
  {
    if (_milestones == null) return new List<string>();
    return _milestones.Select(m => m.Team).Where(t => !string.IsNullOrWhiteSpace(t)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(t => t).ToList()!;
  }

  private List<MilestoneItem> GetFilteredMilestoneItems(List<MilestoneItem> items)
  {
    if (items == null) return new List<MilestoneItem>();
    if (_milestoneFilter == "all") return items;
    if (_milestoneFilter == "record" || _milestoneFilter == "hattrick" || _milestoneFilter == "league" || _milestoneFilter == "tournament")
      return items.Where(i => i.Category == _milestoneFilter).ToList();
    return items.Where(i => string.Equals(i.Team, _milestoneFilter, StringComparison.OrdinalIgnoreCase)).ToList();
  }
}

