                <div class="player-milestones-timeline">
                  <div class="player-milestones-spine"></div>
                  @foreach (var yearGroup in filtered.GroupBy(x => x.Year).OrderByDescending(g => g.Key))
                  {
                    <div class="player-milestones-year-header" data-year="@yearGroup.Key">@yearGroup.Key</div>
                    @foreach (var item in yearGroup.OrderByDescending(x => x.SortDate))
                    {
                      <div class="player-milestones-row">
                        <div class="player-milestone-card @(item.IsFeatured ? "player-milestone-card-featured" : "")">
                          <img src="@(item.IconUrl ?? "/images/player/milestone.png")" alt="" class="player-milestone-card-icon" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null; this.src='/images/player/milestone.png';" />
                          <div class="player-milestone-card-body">
                            <span class="player-milestone-card-title">@item.Title</span>
                            @if (!string.IsNullOrWhiteSpace(item.Team)) { <div class="player-milestone-card-team"><img src="@(item.BadgeUrl ?? "/images/icons/soccer-player.png")" alt="" class="player-milestone-card-badge" onerror="this.style.display='none'" /> @item.Team</div> }
                            <div class="player-milestone-card-meta">
                              <span class="player-milestone-card-date">@item.DateDisplay</span>
                              <span class="player-milestone-chip player-milestone-chip-@(item.Category)">@item.CategoryLabel</span>
                            </div>
                            @if (item.IsFeatured && !string.IsNullOrWhiteSpace(item.Subtitle)) { <span class="player-milestone-card-sub">@item.Subtitle</span> }
                          </div>
                        </div>
                      </div>
