@page "/player/{Id}"
@rendermode RenderMode.InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using SoccerBlast.Shared.Contracts
@using SoccerBlast.Web.Helpers
@inject SoccerBlast.Web.Services.SoccerApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="team-page">
  @if (_loading)
  {
    <div class="team-loading">
      <GlobalSpinner Message="Loading player..." FullPage="true" />
    </div>
  }
  else if (_player is null)
  {
    <div class="team-error">
      <p>Player not found.</p>
      <button class="team-back-btn" @onclick="GoBack" type="button">← Back</button>
    </div>
  }
  else
  {
    <div class="team-hero player-hero" style="background-image: url('@(string.IsNullOrWhiteSpace(_player.BannerUrl) ? "/images/banner/player-banner.jpg" : _player.BannerUrl)');">
      <div class="team-hero-overlay"></div>
      <div class="team-hero-content">
        <button class="team-back-btn" @onclick="GoBack" type="button">Back</button>

        <div class="team-hero-info player-hero-info">
          <div class="player-hero-photo-wrap @(IsPlayerStatusActive(_player.Status) ? "player-hero-status-active" : "player-hero-status-inactive")">
            <img class="player-hero-photo"
                 src="@(_player.PhotoUrl ?? "/images/icons/soccer-player.png")"
                 alt="@_player.Name"
                 loading="lazy"
                 referrerpolicy="no-referrer"
                 onerror="this.onerror=null; this.src='/images/icons/soccer-player.png';" />
            <span class="player-hero-status-tag">@(IsPlayerStatusActive(_player.Status) ? "Active" : (string.IsNullOrWhiteSpace(_player.Status) ? "—" : _player.Status))</span>
          </div>
          <div>
            <h1 class="team-hero-name">@_player.Name</h1>
            <div class="player-hero-meta">
              @if (!string.IsNullOrWhiteSpace(_player.Position))
              {
                <span class="player-pill">@_player.Position</span>
              }
              @if (!string.IsNullOrWhiteSpace(_player.Nationality))
              {
                <span class="player-pill">@(CountryFlagHelper.CountryFlag(_player.Nationality)) @_player.Nationality</span>
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="team-layout">
      <div class="team-tabs">
        <button class="team-tab @(_activeTab == "profile" ? "active" : "")" @onclick='() => _activeTab = "profile"'>
          <img src="/images/player/profile.png" alt="" class="team-tab-icon" />
          <span>Profile</span>
        </button>
        <button class="team-tab @(_activeTab == "career" ? "active" : "")" @onclick='() => _activeTab = "career"'>
          <img src="/images/player/career.png" alt="" class="team-tab-icon" />
          <span>Career</span>
        </button>
        <button class="team-tab @(_activeTab == "honours" ? "active" : "")" @onclick='() => _activeTab = "honours"'>
          <img src="/images/player/honor.png" alt="" class="team-tab-icon" />
          <span>Honours</span>
        </button>
        <button class="team-tab @(_activeTab == "milestones" ? "active" : "")" @onclick='() => _activeTab = "milestones"'>
          <img src="/images/player/milestone.png" alt="" class="team-tab-icon" />
          <span>Milestones</span>
        </button>
        <button class="team-tab @(_activeTab == "contracts" ? "active" : "")" @onclick='() => _activeTab = "contracts"'>
          <img src="/images/player/contract.png" alt="" class="team-tab-icon" />
          <span>Contracts</span>
        </button>
        <button class="team-tab @(_activeTab == "links" ? "active" : "")" @onclick='() => _activeTab = "links"'>
          <img src="/images/teams/media.png" alt="" class="team-tab-icon" />
          <span>Media</span>
        </button>
      </div>
      <div class="team-content">
        @if (_activeTab == "profile")
        {
          <div class="team-tab-content">
            @if (!string.IsNullOrWhiteSpace(_player.PosterUrl))
            {
              <div class="player-profile-layout">
                <div class="player-poster-block">
                  <img src="@_player.PosterUrl" alt="@_player.Name poster" class="player-poster-img" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.display='none'" />
                </div>
                <div class="player-profile-fields">
                  <div class="team-section-block">
                    <div class="team-info-row">
                    @if (_player.DateOfBirth != null)
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Born</span>
                        <span class="team-info-value">@FormatBornWithAge(_player.DateOfBirth)</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.CurrentTeamName))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Current Team</span>
                        <span class="team-info-value">@_player.CurrentTeamName</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Gender))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Gender</span>
                        <span class="team-info-value">@_player.Gender</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Side))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Side</span>
                        <span class="team-info-value">@_player.Side</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.College))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">College</span>
                        <span class="team-info-value">@_player.College</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Height))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Height</span>
                        <span class="team-info-value">@_player.Height</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Weight))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Weight</span>
                        <span class="team-info-value">@_player.Weight</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.BirthLocation))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Birth Location</span>
                        <span class="team-info-value">@_player.BirthLocation</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Ethnicity))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Ethnicity</span>
                        <span class="team-info-value">@_player.Ethnicity</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Agent))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Agent</span>
                        <span class="team-info-value">@_player.Agent</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Wage))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Wage</span>
                        <span class="team-info-value">@_player.Wage</span>
                      </div>
                    }
                  </div>
                </div>
              </div>
            </div>
            }
            else
            {
              <div class="player-profile-fields">
                <div class="team-section-block">
                  <div class="team-info-row">
                    @if (_player.DateOfBirth != null)
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Born</span>
                        <span class="team-info-value">@FormatBornWithAge(_player.DateOfBirth)</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.CurrentTeamName))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Current Team</span>
                        <span class="team-info-value">@_player.CurrentTeamName</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Gender))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Gender</span>
                        <span class="team-info-value">@_player.Gender</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Side))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Side</span>
                        <span class="team-info-value">@_player.Side</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.College))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">College</span>
                        <span class="team-info-value">@_player.College</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Height))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Height</span>
                        <span class="team-info-value">@_player.Height</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Weight))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Weight</span>
                        <span class="team-info-value">@_player.Weight</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.BirthLocation))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Birth Location</span>
                        <span class="team-info-value">@_player.BirthLocation</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Ethnicity))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Ethnicity</span>
                        <span class="team-info-value">@_player.Ethnicity</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Agent))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Agent</span>
                        <span class="team-info-value">@_player.Agent</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_player.Wage))
                    {
                      <div class="team-info-item">
                        <span class="team-info-label">Wage</span>
                        <span class="team-info-value">@_player.Wage</span>
                      </div>
                    }
                  </div>
                </div>
              </div>
            }
            @if (!string.IsNullOrWhiteSpace(_player.Description))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Description</h3>
                <div class="player-description">@_player.Description</div>
              </div>
            }
            @if (!string.IsNullOrWhiteSpace(_player.SeasonStats))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Season Stats</h3>
                <div class="player-season-stats">@_player.SeasonStats</div>
              </div>
            }
            @if (!HasAnyEnrichment())
            {
              <p class="player-no-enrichment small-muted">Career, honours, contracts and media are in the other tabs when provided by the data source.</p>
            }
          </div>
        }
        @if (_activeTab == "career")
        {
          <div class="team-tab-content player-career-timeline-wrap">
            @if (_formerTeams != null && _formerTeams.Count > 0 && _player != null)
            {
              var entries = GetCareerEntriesOrderedByJoined();
              var summary = GetCareerSummary(entries);
              <h3 class="team-block-title">Former Clubs</h3>
              <div class="player-career-summary">
                @if (summary.CareerStartYear.HasValue) { <span>Career start: <strong>@summary.CareerStartYear</strong></span> }
                <span>Club stints: <strong>@summary.ClubStints</strong></span>
                <span>Clubs: <strong>@summary.UniqueClubs</strong></span>
                @if (!string.IsNullOrWhiteSpace(summary.LongestSpell)) { <span>Longest spell: <strong>@summary.LongestSpell</strong></span> }
                @if (!string.IsNullOrWhiteSpace(summary.NationalTeamSpan)) { <span>National team: <strong>@summary.NationalTeamSpan</strong></span> }
              </div>
              <div class="player-career-timeline">
                <div class="player-career-spine"></div>
                @{
                  var inYouthBlock = false;
                }
                @foreach (var e in entries)
                {
                  if (e.IsYouth && !inYouthBlock) { inYouthBlock = true; <div class="player-career-dev-label">Development Years</div> }
                  if (!e.IsYouth && inYouthBlock) { inYouthBlock = false; }
                  var laneClass = e.IsNational ? "player-career-node-national" : "player-career-node-club";
                  var nodeClass = "player-career-node " + laneClass + (e.IsYouth ? " player-career-node-youth" : "");
                  var durationBarPct = Math.Min(100, 20 + (int)(Math.Sqrt(Math.Max(0, e.DurationYears)) * 12));
                  <div class="player-career-row">
                    <div class="@nodeClass" style="--duration-pct: @(durationBarPct);">
                      <div class="player-career-node-bar" title="@(e.DurationYears > 0 ? FormatDuration(e.DurationYears) : "")">
                        @if (e.DurationYears > 0)
                        {
                          <span class="player-career-node-bar-years">@(FormatDuration(e.DurationYears))</span>
                        }
                      </div>
                      <img src="@(e.TeamBadge ?? "/images/icons/soccer-player.png")" alt="" class="player-career-node-badge" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null; this.src='/images/icons/soccer-player.png';" />
                      <div class="player-career-node-body">
                        <span class="player-career-node-name">@(e.TeamName ?? "—")</span>
                        <span class="player-career-node-years">@(e.YearStart ?? e.Joined ?? "?") – @(e.YearEnd ?? e.Departed ?? "?")</span>
                        @if (e.DurationYears > 0) { <span class="player-career-node-duration">@(FormatDuration(e.DurationYears))</span> }
                        <div class="player-career-node-chips">
                          @if (e.IsYouth) { <span class="player-career-chip player-career-chip-youth">Youth Teams</span> } else { <span class="player-career-chip player-career-chip-senior">Senior</span> }
                          @if (!string.IsNullOrWhiteSpace(e.ContractType) && !e.IsYouth) { <span class="player-career-chip">@e.ContractType</span> }
                          @if (e.IsReturn) { <span class="player-career-chip player-career-chip-return">Return</span> }
                          @if (e.IsNational) { <span class="player-career-chip player-career-chip-national">National Team</span> }
                        </div>
                      </div>
                    </div>
                  </div>
                }
              </div>
              <p class="player-career-source-note small-muted">Based on available transfer history from provider.</p>
            }
            else
            {
              <p class="player-no-enrichment small-muted">No career or former teams data available.</p>
            }
          </div>
        }
        @if (_activeTab == "honours")
        {
          <div class="team-tab-content player-honours-cabinet-wrap">
            @if (_honours != null && _honours.Count > 0)
            {
              var groups = GetHonourGroups();
              var summary = GetHonoursSummary(groups);
              var filteredGroups = GetFilteredAndSortedHonourGroups(groups);
              <h3 class="team-block-title">Honours & Awards</h3>
              <p class="player-honours-subtitle">Career achievements grouped by competition and award type.</p>
              <div class="player-honours-summary-band">
                <span>Total honors: <strong>@summary.TotalCount</strong></span>
                <span>Unique types: <strong>@summary.UniqueTypes</strong></span>
                <span>Team trophies: <strong>@summary.TeamCount</strong></span>
                <span>Individual: <strong>@summary.IndividualCount</strong></span>
                @if (!string.IsNullOrWhiteSpace(summary.MostFrequent)) { <span>Most frequent: <strong>@summary.MostFrequent</strong></span> }
                @if (!string.IsNullOrWhiteSpace(summary.PeakPeriod)) { <span>Peak: <strong>@summary.PeakPeriod</strong></span> }
              </div>
              <div class="player-honours-controls">
                <span class="player-honours-control-label">Filter:</span>
                <div class="player-honours-filters">
                  <button type="button" class="player-honours-filter @(_honourFilter == "all" ? "active" : "")" @onclick='() => _honourFilter = "all"'>All</button>
                  <button type="button" class="player-honours-filter @(_honourFilter == "team" ? "active" : "")" @onclick='() => _honourFilter = "team"'>Team</button>
                  <button type="button" class="player-honours-filter @(_honourFilter == "individual" ? "active" : "")" @onclick='() => _honourFilter = "individual"'>Individual</button>
                  <button type="button" class="player-honours-filter @(_honourFilter == "scorer" ? "active" : "")" @onclick='() => _honourFilter = "scorer"'>Scorer</button>
                  <button type="button" class="player-honours-filter @(_honourFilter == "bestxi" ? "active" : "")" @onclick='() => _honourFilter = "bestxi"'>Best XI</button>
                  <button type="button" class="player-honours-filter @(_honourFilter == "youth" ? "active" : "")" @onclick='() => _honourFilter = "youth"'>Youth</button>
                </div>
                <span class="player-honours-control-label">Sort:</span>
                <div class="sb-filter-custom @(_honourSortOpen ? "sb-filter-open" : "")">
                  <button type="button" class="sb-filter-btn" @onclick='() => _honourSortOpen = !_honourSortOpen'>
                    <span class="sb-filter-text">@( _honourSort == "prestige" ? "Prestige" : _honourSort == "count" ? "Count" : _honourSort == "latest" ? "Latest" : "Alphabetical" )</span>
                    <span class="sb-filter-arrow">▼</span>
                  </button>
                  @if (_honourSortOpen)
                  {
                    <div class="sb-filter-menu">
                      <button type="button" class="sb-filter-option @(_honourSort == "prestige" ? "active" : "")" @onclick='() => { _honourSort = "prestige"; _honourSortOpen = false; }'>Prestige</button>
                      <button type="button" class="sb-filter-option @(_honourSort == "count" ? "active" : "")" @onclick='() => { _honourSort = "count"; _honourSortOpen = false; }'>Count</button>
                      <button type="button" class="sb-filter-option @(_honourSort == "latest" ? "active" : "")" @onclick='() => { _honourSort = "latest"; _honourSortOpen = false; }'>Latest</button>
                      <button type="button" class="sb-filter-option @(_honourSort == "alpha" ? "active" : "")" @onclick='() => { _honourSort = "alpha"; _honourSortOpen = false; }'>Alphabetical</button>
                    </div>
                  }
                </div>
              </div>
              <div class="player-honours-controls player-honours-controls-row">
                <span class="player-honours-control-label">View:</span>
                <div class="player-honours-view-toggle">
                  <button type="button" class="player-honours-view-btn @(_honourView == "cabinet" ? "active" : "")" @onclick='() => _honourView = "cabinet"'>Cabinet</button>
                  <button type="button" class="player-honours-view-btn @(_honourView == "timeline" ? "active" : "")" @onclick='() => _honourView = "timeline"'>Timeline</button>
                </div>
              </div>
              @if (_honourView == "timeline")
              {
                <div class="player-honours-timeline-list">
                  @foreach (var item in GetHonoursTimelineList())
                  {
                    <div class="player-honours-timeline-item">
                      <span class="player-honours-timeline-year">@item.SeasonDisplay</span>
                      <span class="player-honours-timeline-name">@item.Name</span>
                      @if (!string.IsNullOrWhiteSpace(item.Competition)) { <span class="player-honours-timeline-meta">@item.Competition</span> }
                    </div>
                  }
                </div>
              }
              else
              {
                var byCategory = filteredGroups.GroupBy(g => g.Category).OrderBy(g => HonourCategoryOrder(g.Key)).ToList();
                @foreach (var cat in byCategory)
                {
                  var catKey = cat.Key;
                  var isCollapsed = _honoursCollapsed.Contains(catKey);
                  <div class="player-honours-category">
                    <button type="button" class="player-honours-category-header" @onclick='() => ToggleHonoursCategory(catKey)'>
                      <span class="player-honours-category-title">@HonourCategoryLabel(catKey)</span>
                      <span class="player-honours-category-count">@cat.Count()</span>
                      <span class="player-honours-category-chevron">@(isCollapsed ? "▶" : "▼")</span>
                    </button>
                    @if (!isCollapsed)
                    {
                      <div class="player-honours-card-grid">
                        @foreach (var g in cat)
                        {
                          var imgUrl = g.IconUrl ?? "/images/player/honor.png";
                          var prestigeClass = g.IsPrestige ? " player-honours-card-prestige" : (g.IsRecurring ? " player-honours-card-recurring" : "");
                          <div class="player-honours-card@(prestigeClass)">
                            <img src="@imgUrl" alt="" class="player-honours-card-icon" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null; this.src='/images/player/honor.png';" />
                            <div class="player-honours-card-body">
                              <span class="player-honours-card-name">@g.DisplayName</span>
                              @if (!string.IsNullOrWhiteSpace(g.Competition)) { <span class="player-honours-card-sub">@g.Competition</span> }
                              <div class="player-honours-card-chips">
                                @foreach (var chip in g.SeasonChips.Take(_honoursExpandedCard == g.DisplayName ? 999 : 6))
                                {
                                  <span class="player-honours-year-chip">@chip</span>
                                }
                                @if (g.SeasonChips.Count > 6 && _honoursExpandedCard != g.DisplayName)
                                {
                                  <button type="button" class="player-honours-more-btn" @onclick='() => _honoursExpandedCard = _honoursExpandedCard == g.DisplayName ? null : g.DisplayName'>+@(g.SeasonChips.Count - 6) more</button>
                                }
                              </div>
                              @if (g.FirstWonYear != null || g.LastWonYear != null)
                              {
                                <span class="player-honours-card-meta">First: @(g.FirstWonYear ?? "—") · Last: @(g.LastWonYear ?? "—")@(g.SpanYears.HasValue ? $" · Span: {g.SpanYears}y" : "")</span>
                              }
                            </div>
                            <div class="player-honours-card-count">
                              <span class="player-honours-card-number">@g.Count</span>
                              <span class="player-honours-card-label">@(g.Count == 1 ? "win" : "wins")</span>
                            </div>
                          </div>
                        }
                      </div>
                    }
                  </div>
                }
              }
            }
            else
            {
              <p class="player-no-enrichment small-muted">No honours data available.</p>
            }
          </div>
        }
        @if (_activeTab == "milestones")
        {
          <div class="team-tab-content player-milestones-moments-wrap">
            @if (_milestones != null && _milestones.Count > 0)
            {
              var milestoneItems = GetMilestoneItems();
              var filtered = GetFilteredMilestoneItems(milestoneItems);
              var msSummary = GetMilestonesSummary(milestoneItems);
              <h3 class="team-block-title">Career Moments</h3>
              <p class="player-milestones-subtitle">Milestones &amp; records — timeline of career moments.</p>
              <div class="player-milestones-summary-band">
                <span>Total: <strong>@msSummary.Total</strong></span>
                <span>Hat-tricks: <strong>@msSummary.HatTricks</strong></span>
                <span>Career landmarks: <strong>@msSummary.Records</strong></span>
                <span>Tournament: <strong>@msSummary.Tournament</strong></span>
                @if (!string.IsNullOrWhiteSpace(msSummary.MostRecent)) { <span>Most recent: <strong>@msSummary.MostRecent</strong></span> }
              </div>
              <div class="player-milestones-controls">
                <span class="player-honours-control-label">Filter:</span>
                <div class="player-honours-filters">
                  <button type="button" class="player-honours-filter @(_milestoneFilter == "all" ? "active" : "")" @onclick='() => _milestoneFilter = "all"'>All</button>
                  <button type="button" class="player-honours-filter @(_milestoneFilter == "record" ? "active" : "")" @onclick='() => _milestoneFilter = "record"'>Records</button>
                  <button type="button" class="player-honours-filter @(_milestoneFilter == "hattrick" ? "active" : "")" @onclick='() => _milestoneFilter = "hattrick"'>Hat-Tricks</button>
                  <button type="button" class="player-honours-filter @(_milestoneFilter == "league" ? "active" : "")" @onclick='() => _milestoneFilter = "league"'>League Awards</button>
                  <button type="button" class="player-honours-filter @(_milestoneFilter == "tournament" ? "active" : "")" @onclick='() => _milestoneFilter = "tournament"'>Tournament</button>
                  @foreach (var team in GetMilestoneTeams())
                  {
