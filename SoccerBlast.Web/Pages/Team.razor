@page "/team/{Id}"
@using Microsoft.AspNetCore.Components.Web
@rendermode RenderMode.InteractiveServer
@using SoccerBlast.Shared.Contracts
@using SoccerBlast.Web.Helpers
@using SoccerBlast.Web.Services
@inject SoccerBlast.Web.Services.SoccerApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="team-page">
  @if (_loading)
  {
    <div class="team-loading">
      <GlobalSpinner Message="Loading team..." FullPage="true" />
    </div>
  }
  else if (_team is null)
  {
    <div class="team-error">
      <p>Team not found.</p>
      <button class="team-back-btn" @onclick="GoBack">← Back</button>
    </div>
  }
  else
  {
    <!-- Hero Section with Banner -->
    <div class="team-hero" style="background-image: url('@(string.IsNullOrWhiteSpace(_team.Profile?.BannerUrl) ? "images/teams/team-banner.jpg" : _team.Profile.BannerUrl)')">
      <div class="team-hero-overlay"></div>
      <div class="team-hero-content">
        <button class="team-back-btn" @onclick="GoBack">Back</button>
        
        <div class="team-hero-info">
          <img class="team-hero-crest"
               src="@(string.IsNullOrWhiteSpace(_team.CrestUrl) ? "images/teams/placeholder.png" : _team.CrestUrl)"
               alt="@_team.Name"
               loading="lazy"
               referrerpolicy="no-referrer"
               onerror="this.onerror=null; this.src='images/teams/placeholder.png';" />
          
          <h1 class="team-hero-name">@_team.Name</h1>
          
          @{
            var firstLeague = !string.IsNullOrWhiteSpace(_team.Profile?.Leagues) 
              ? _team.Profile.Leagues.Split(',', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.Trim() 
              : null;
          }
          @if (!string.IsNullOrEmpty(firstLeague))
          {
            <p class="team-hero-leagues">@firstLeague</p>
          }
        </div>
      </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_toast))
    {
      <div class="team-toast">@_toast</div>
    }

    <!-- Tabs and Content Layout -->
    <div class="team-layout">
      <!-- Tabs Navigation -->
      <div class="team-tabs">
        <button class="team-tab @(_activeTab == "overview" ? "active" : "")" @onclick='() => _activeTab = "overview"'>
          <img src="/images/teams/overview.png" alt="Overview" class="team-tab-icon" />
          <span>Overview</span>
        </button>
        <button class="team-tab @(_activeTab == "stadium" ? "active" : "")" @onclick="OnStadiumTabClick">
          <img src="/images/teams/stadium-cenit-view-.png" alt="Stadium" class="team-tab-icon" />
          <span>Stadium</span>
        </button>
        <button class="team-tab @(_activeTab == "about" ? "active" : "")" @onclick='() => _activeTab = "about"'>
          <img src="/images/teams/about.png" alt="About" class="team-tab-icon" />
          <span>About</span>
        </button>
        <button class="team-tab @(_activeTab == "matches" ? "active" : "")" @onclick="@(() => LoadMatchesTab())">
            <img src="/images/teams/tickets.png" alt="Matches" class="team-tab-icon" />
            <span>Matches</span>
        </button>
        <button class="team-tab @(_activeTab == "kit" ? "active" : "")" @onclick='() => _activeTab = "kit"'>
          <img src="/images/teams/media.png" alt="Club Hub" class="team-tab-icon" />
          <span>Club Hub</span>
        </button>
        <button class="team-tab @(_activeTab == "players" ? "active" : "")" @onclick="@(() => LoadPlayersTab())">
          <img src="/images/teams/soccer-player.png" alt="Players" class="team-tab-icon" />
          <span>Players</span>
        </button>
      </div>

      <!-- Content Section -->
      <div class="team-content">
      @if (_team.Profile != null)
      {
        @if (_activeTab == "overview")
        {
          <!-- Team Overview -->
          <div class="team-tab-content">
            <div class="team-info-row">
              @if (_team.Profile.FormedYear.HasValue)
              {
                <div class="team-info-item">
                  <span class="team-info-label">Founded</span>
                  <span class="team-info-value">@_team.Profile.FormedYear.Value</span>
                </div>
              }
              
              @if (!string.IsNullOrWhiteSpace(_team.Profile.Location))
              {
                <div class="team-info-item">
                  <span class="team-info-label">Location</span>
                  <span class="team-info-value">@_team.Profile.Location</span>
                </div>
              }
              
              @if (!string.IsNullOrWhiteSpace(_team.Profile.Keywords))
              {
                <div class="team-info-item">
                  <span class="team-info-label">Nicknames</span>
                  <span class="team-info-value">@_team.Profile.Keywords</span>
                </div>
              }
            </div>

            @if (!string.IsNullOrWhiteSpace(_team.Profile.Leagues))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Competitions</h3>
                <div class="team-leagues-grid">
                  @{
                    var leagueEntries = _team.Profile.LeaguesWithBadges ?? _team.Profile.Leagues
                      .Split(',', StringSplitOptions.RemoveEmptyEntries)
                      .Select(s => new LeagueEntryDto(s.Trim(), null))
                      .Where(e => !string.IsNullOrEmpty(e.Name))
                      .ToList();
                  }
                  @foreach (var entry in leagueEntries)
                  {
                    var iconPath = entry.BadgeUrl ?? LeagueIconMap.GetByName(entry.Name) ?? LeagueIconMap.DefaultLeagueIcon;
                    <div class="team-league-item">
                      <img src="@iconPath"
                           alt="@entry.Name"
                           class="team-league-icon"
                           loading="lazy"
                           referrerpolicy="no-referrer"
                           onerror="this.onerror=null; this.src='/images/icons/world-cup.png';" />
                      @if (entry.Id.HasValue)
                      { <a href="/competition/@entry.Id.Value" class="team-league-name team-league-link">@entry.Name</a> }
                      else { <span class="team-league-name">@entry.Name</span> }
                    </div>
                  }
                </div>
              </div>
            }

            @if (!string.IsNullOrWhiteSpace(_team?.SportsDbTeamId))
            {
              <div class="team-section-block team-trophies-section">
                <h3 class="team-block-title">Trophies</h3>
                @if (_teamHonours != null && _teamHonours.Count > 0)
                {
                  <div class="player-honours-controls">
                    <span class="player-honours-control-label">Type:</span>
                    <div class="player-honours-filters">
                      <button type="button" class="player-honours-filter @(_trophyFilter == "all" ? "active" : "")" @onclick='() => _trophyFilter = "all"'>All</button>
                      <button type="button" class="player-honours-filter @(_trophyFilter == "league" ? "active" : "")" @onclick='() => _trophyFilter = "league"'>League</button>
                      <button type="button" class="player-honours-filter @(_trophyFilter == "cup" ? "active" : "")" @onclick='() => _trophyFilter = "cup"'>Cup</button>
                      <button type="button" class="player-honours-filter @(_trophyFilter == "award" ? "active" : "")" @onclick='() => _trophyFilter = "award"'>Award</button>
                    </div>
                  </div>
                  <div class="player-honours-card-grid">
                    @foreach (var h in GetFilteredTeamHonours())
                    {
                      var imgUrl = !string.IsNullOrWhiteSpace(h.TrophyImageUrl) ? h.TrophyImageUrl : "/images/player/honor.png";
                      <a href="@h.HonourUrl" target="_blank" rel="noopener noreferrer" class="player-honours-card team-trophy-card">
                        <img src="@imgUrl" alt="" class="player-honours-card-icon" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null; this.src='/images/player/honor.png';" />
                        <div class="player-honours-card-body">
                          <span class="player-honours-card-name">@(h.Title ?? h.Slug)</span>
                          <div class="player-honours-card-chips">
                            @if (h.WinnerYears != null)
                            {
                              @foreach (var yr in h.WinnerYears.Take(_expandedTrophy == h.IdHonour ? 999 : 6))
                              {
                                <span class="player-honours-year-chip">@yr</span>
                              }
                              @if (h.WinnerYears.Count > 6 && _expandedTrophy != h.IdHonour)
                              {
                                <button type="button" class="player-honours-more-btn" @onclick='() => _expandedTrophy = _expandedTrophy == h.IdHonour ? 0 : h.IdHonour' @onclick:stopPropagation="true">+@(h.WinnerYears.Count - 6) more</button>
                              }
                            }
                          </div>
                        </div>
                        <div class="player-honours-card-count">
                          <span class="player-honours-card-number">@h.Wins</span>
                          <span class="player-honours-card-label">@(h.Wins == 1 ? "win" : "wins")</span>
                        </div>
                      </a>
                    }
                  </div>
                }
                else
                {
                  <p class="team-trophies-empty">No trophies for this team. Run <code>dotnet run --project Scripts/ScrapeTeamHonours -- --db sportsdb_cache.db</code>, then call <code>POST /api/admin/import/honours</code> to load data into the app.</p>
                }
              </div>
            }
          </div>
        }
        else if (_activeTab == "stadium")
        {
          <!-- Stadium / Venue tab (enriched from lookup/venue) -->
          <div class="team-tab-content">
            @if (!string.IsNullOrWhiteSpace(_team.Profile.StadiumName))
            {
              @if (_loadingStadium)
              {
                <div class="team-stadium-loading">
                  <GlobalSpinner Message="Loading venue..." />
                </div>
              }
              else if (_stadium != null)
              {
                <div class="team-stadium-enriched">
                  <div class="team-stadium-hero">
                    <img src="@(string.IsNullOrWhiteSpace(_stadium.ThumbUrl) ? "/images/teams/court.jpg" : _stadium.ThumbUrl)"
                         alt="@_stadium.Name"
                         class="team-stadium-thumb"
                         loading="lazy"
                         referrerpolicy="no-referrer"
                         onerror="this.onerror=null; this.src='/images/teams/court.jpg';" />
                    <div class="team-stadium-hero-overlay"></div>
                    <h2 class="team-stadium-title">@_stadium.Name</h2>
                  </div>
                  <div class="team-stadium-meta">
                    @if (_stadium.Capacity.HasValue)
                    {
                      <div class="team-stadium-meta-item">
                        <span class="team-stadium-meta-label">Capacity</span>
                        <span class="team-stadium-meta-value">@_stadium.Capacity.Value.ToString("N0")</span>
                      </div>
                    }
                    @if (_stadium.FormedYear.HasValue)
                    {
                      <div class="team-stadium-meta-item">
                        <span class="team-stadium-meta-label">Est.</span>
                        <span class="team-stadium-meta-value">@_stadium.FormedYear</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_stadium.Location))
                    {
                      <div class="team-stadium-meta-item">
                        <span class="team-stadium-meta-label">Location</span>
                        <span class="team-stadium-meta-value">@_stadium.Location</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_stadium.Cost))
                    {
                      <div class="team-stadium-meta-item">
                        <span class="team-stadium-meta-label">Cost</span>
                        <span class="team-stadium-meta-value">@_stadium.Cost</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_stadium.Id))
                    {
                        <a href="/venue/@_stadium.Id" class="team-stadium-detail-btn">View stadium</a>
                    }
                  </div>
                  @if (!string.IsNullOrWhiteSpace(_stadium.Description))
                  {
                    <div class="team-section-block team-stadium-description">
                      <h3 class="team-block-title">About</h3>
                      <p class="team-stadium-description-text">@_stadium.Description</p>
                    </div>
                  }
                  @if (_stadium.FanartUrls != null && _stadium.FanartUrls.Count > 0)
                  {
                    <div class="team-section-block">
                      <h3 class="team-block-title">Gallery</h3>
                      <div class="sb-gallery-grid">
                        @for (var i = 0; i < _stadium.FanartUrls.Count; i++)
                        {
                          var url = _stadium.FanartUrls[i];
                          <img src="@url"
                               alt="@_stadium.Name gallery"
                               class="sb-gallery-img"
                               loading="lazy"
                               referrerpolicy="no-referrer"
                               onerror="this.style.display='none';"
                               @onclick="() => OpenStadiumGallery(i)" />
                        }
                      </div>
                    </div>
                  }
                  @if ((_stadium.Latitude.HasValue && _stadium.Longitude.HasValue) || !string.IsNullOrWhiteSpace(_stadium.MapCoordinates))
                  {
                    <LocationMap MapElementId="stadium-map" Latitude="@_stadium.Latitude" Longitude="@_stadium.Longitude" MapCoordinates="@_stadium.MapCoordinates" Country="@_stadium.Country" VenueName="@_stadium.Name" />
                  }
                </div>
              }
              else
              {
                <div class="team-stadium-fallback">
                  <div class="team-stadium-header">
                    <img src="/images/teams/court.jpg" alt="Stadium" class="team-stadium-icon" />
                    <h3 class="team-stadium-name">@_team.Profile.StadiumName</h3>
                  </div>
                  <div class="team-stadium-details">
                    @if (_team.Profile.StadiumCapacity.HasValue)
                    {
                      <div class="team-stadium-detail">
                        <span class="team-detail-label">Capacity</span>
                        <span class="team-detail-value">@_team.Profile.StadiumCapacity.Value.ToString("N0")</span>
                      </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_team.Profile.StadiumLocation))
                    {
                      <div class="team-stadium-detail">
                        <span class="team-detail-label">Location</span>
                        <span class="team-detail-value">@_team.Profile.StadiumLocation</span>
                      </div>
                    }
                  </div>
                </div>
              }
            }
            else
            {
              <div class="team-empty">
                <h3>No stadium info</h3>
                <p class="small-muted">Stadium not set for this team.</p>
              </div>
            }
          </div>
        }
        else if (_activeTab == "about")
        {
          <!-- About Section -->
          <div class="team-tab-content">
            @if (!string.IsNullOrWhiteSpace(_team.Profile.DescriptionEn))
            {
              <div class="team-about-text">
                @_team.Profile.DescriptionEn
              </div>
            }
          </div>
        }
        else if (_activeTab == "matches")
        {
          <div class="team-tab-content">
            <TeamMatchesTab
              IsActive="@(_activeTab == "matches")"
              TeamName="@(_team?.Name ?? "")"
              TeamId="@(_team?.Id)" 
              IsExternalTeam="@IsExternalTeam"
              SportsDbTeamId="@_team?.SportsDbTeamId"
              From="@_matchesFrom"
              To="@_matchesTo"
              RangeChanged="OnMatchRangeChanged" />
          </div>
        }

                else if (_activeTab == "kit")
        {
          <!-- Team Kit, Fanart (v2), Social, Primary Colours -->
          <div class="team-tab-content">
            @if (!string.IsNullOrWhiteSpace(_team.Profile.PrimaryColor) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.SecondaryColor) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.TertiaryColor))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Club Colours</h3>
                <div class="team-colours-row">
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.PrimaryColor))
                  {
                    <div class="team-colour-swatch" style="background: @ToCssColor(_team.Profile.PrimaryColor);" title="Primary">Primary</div>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.SecondaryColor))
                  {
                    <div class="team-colour-swatch" style="background: @ToCssColor(_team.Profile.SecondaryColor);" title="Secondary">Secondary</div>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.TertiaryColor))
                  {
                    <div class="team-colour-swatch" style="background: @ToCssColor(_team.Profile.TertiaryColor);" title="Tertiary">Tertiary</div>
                  }
                </div>
              </div>
            }
            @if (_team.Profile.FanartUrls != null && _team.Profile.FanartUrls.Count > 0)
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Gallery</h3>
                <div class="sb-gallery-grid">
                  @for (var i = 0; i < _team.Profile.FanartUrls.Count; i++)
                  {
                    var url = _team.Profile.FanartUrls[i];
                    <img src="@url"
                         alt="@_team.Name gallery image"
                         class="sb-gallery-img"
                         loading="lazy"
                         referrerpolicy="no-referrer"
                         onerror="this.style.display='none';"
                         @onclick="() => OpenGallery(i)" />
                  }
                </div>
              </div>
            }
            @if (!string.IsNullOrWhiteSpace(_team.Profile.JerseyUrl))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Team Kit</h3>
                <div class="team-kit-display">
                  <img src="@_team.Profile.JerseyUrl"
                       alt="@_team.Name kit"
                       class="team-kit-image"
                       loading="lazy"
                       referrerpolicy="no-referrer"
                       onerror="this.style.display='none';" />
                </div>
              </div>
            }

            @if (!string.IsNullOrWhiteSpace(_team.Profile.Website) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.Facebook) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.Twitter) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.Instagram) ||
                 !string.IsNullOrWhiteSpace(_team.Profile.Youtube))
            {
              <div class="team-section-block">
                <h3 class="team-block-title">Social Media</h3>
                <div class="team-social-links">
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.Website))
                  {
                    <a href="@_team.Profile.Website" target="_blank" rel="noopener noreferrer" class="team-social-link">
                      <span>Website</span>
                    </a>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.Twitter))
                  {
                    <a href="@_team.Profile.Twitter" target="_blank" rel="noopener noreferrer" class="team-social-link team-social-link-icon" aria-label="Twitter">
                      <img src="/images/teams/media/twitter.png" alt="Twitter" class="team-social-icon" />
                    </a>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.Facebook))
                  {
                    <a href="@_team.Profile.Facebook" target="_blank" rel="noopener noreferrer" class="team-social-link team-social-link-icon" aria-label="Facebook">
                      <img src="/images/teams/media/facebook.png" alt="Facebook" class="team-social-icon" />
                    </a>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.Instagram))
                  {
                    <a href="@_team.Profile.Instagram" target="_blank" rel="noopener noreferrer" class="team-social-link team-social-link-icon" aria-label="Instagram">
                      <img src="/images/teams/media/instagram.png" alt="Instagram" class="team-social-icon" />
                    </a>
                  }
                  @if (!string.IsNullOrWhiteSpace(_team.Profile.Youtube))
                  {
                    <a href="@_team.Profile.Youtube" target="_blank" rel="noopener noreferrer" class="team-social-link team-social-link-icon" aria-label="YouTube">
                      <img src="/images/teams/media/youtube.png" alt="YouTube" class="team-social-icon" />
                    </a>
                  }
                </div>
              </div>
            }
          </div>
        }
        else if (_activeTab == "players")
        {
          <!-- Players Roster -->
          <div class="team-tab-content">
            <div class="team-viewbar">
                <span class="team-viewbar-label">View:</span>
                <button class="team-viewbtn @(_playerView==PlayerViewMode.Cutouts?"active":"")"
                        @onclick="() => _playerView = PlayerViewMode.Cutouts">Cutouts</button>
                <button class="team-viewbtn @(_playerView==PlayerViewMode.Thumbs?"active":"")"
                        @onclick="() => _playerView = PlayerViewMode.Thumbs">Thumbs</button>
                <button class="team-viewbtn @(_playerView==PlayerViewMode.Renders?"active":"")"
                        @onclick="() => _playerView = PlayerViewMode.Renders">Renders</button>
                <button class="team-viewbtn @(_playerView==PlayerViewMode.Cartoon?"active":"")"
                        @onclick="() => _playerView = PlayerViewMode.Cartoon">Cartoon</button>
            </div>
            @if (_loadingPlayers)
            {
              <div class="team-players-loading">
                <GlobalSpinner Message="Loading players..." />
              </div>
            }
            else if (_players != null && _players.Count > 0)
            {
              var byPosition = _players
                .GroupBy(p => string.IsNullOrWhiteSpace(p.Position) ? "Other" : (p.Position ?? "Other").Trim())
                .OrderBy(g => PositionSortOrder(g.Key))
                .ToList();
              @foreach (var group in byPosition)
              {
                <div class="team-players-by-position">
                  <h3 class="team-players-position-title">@group.Key</h3>
                  <div class="team-players-grid">
                    @foreach (var player in group)
                    {
                      <div class="team-player-card" @onclick="() => GoPlayer(player)" role="button" tabindex="0" style="cursor: @(string.IsNullOrWhiteSpace(player.SportsDbPlayerId) ? "default" : "pointer");">
                        <img src="@(PickPlayerImage(player))"
                            alt="@player.Name"
                            class="team-player-photo"
                            loading="lazy"
                            referrerpolicy="no-referrer"
                            onerror="this.src='/images/icons/soccer-player.png';" />
                        <div class="team-player-info">
                          <h4 class="team-player-name">@player.Name</h4>
                          <div class="team-player-number">@(string.IsNullOrWhiteSpace(player.JerseyNumber) ? "—" : "#" + player.JerseyNumber)</div>
                          <div class="team-player-tags">
                            @if (!string.IsNullOrEmpty(player.Nationality))
                            {
                              <span class="team-player-tag">@(CountryFlagHelper.CountryFlag(player.Nationality)) @player.Nationality</span>
                            }
                            @if (player.Age.HasValue)
                            {
                              <span class="team-player-tag">@player.Age yrs</span>
                            }
                            @if (!string.IsNullOrEmpty(player.Wage))
                            {
                              <span class="team-player-tag">@player.Wage</span>
                            }
                            @if (!string.IsNullOrEmpty(player.StrSigning))
                            {
                              <span class="team-player-tag">@player.StrSigning</span>
                            }
                            @if (!string.IsNullOrEmpty(player.Height))
                            {
                              <span class="team-player-tag">@player.Height</span>
                            }
                            @if (!string.IsNullOrEmpty(player.Weight))
                            {
                              <span class="team-player-tag">@player.Weight</span>
                            }
                          </div>
                        </div>
                      </div>
                    }
                  </div>
                </div>
              }
            }
            else
            {
              <div class="team-empty">
                <h3>No players found</h3>
                <p class="small-muted">Player roster not available</p>
              </div>
            }
          </div>
        }
      }
      else
      {
        <div class="team-tab-content">
          @if (_profileUnavailable)
          {
            <div class="team-empty">
              <h3>Profile not available</h3>
              <p class="small-muted">No extended profile for this team in the current source.</p>
            </div>
          }
          else
          {
            <div class="team-empty team-empty-loading">
              <GlobalSpinner Message="Loading team profile..." />
              @if (_team?.Id > 0)
              {
                <button type="button" class="team-sync-btn" @onclick="SyncProfileInBackground" disabled="@_syncing">
                  @(_syncing ? "Syncing…" : "Sync profile now")
                </button>
              }
            </div>
          }
        </div>
      }
      </div>
    </div>
  }

  @if (_isGalleryOpen && _galleryUrls != null && _galleryUrls.Count > 0)
  {
    <div class="sb-gallery-overlay" @onclick="CloseGallery">
      <div class="sb-gallery-modal" @onclick:stopPropagation="true">
        <button type="button" class="sb-gallery-close" @onclick="CloseGallery" aria-label="Close gallery">×</button>
        <button type="button" class="sb-gallery-nav sb-gallery-nav-prev" @onclick="PrevGalleryImage" aria-label="Previous image">‹</button>
        <img src="@_galleryUrls[_activeGalleryIndex]"
             alt="Gallery image"
             class="sb-gallery-img"
             loading="lazy"
             referrerpolicy="no-referrer"
             onerror="this.style.display='none';" />
        <button type="button" class="sb-gallery-nav sb-gallery-nav-next" @onclick="NextGalleryImage" aria-label="Next image">›</button>
      </div>
    </div>
  }
</div>

@code {
  [Parameter] public string? Id { get; set; }

  private bool _loading = true;
  private bool _syncing;
  private string? _toast;
  private string _activeTab = "overview";

  private TeamDetailDto? _team;
  private AutoSyncLoop? _syncLoop;
  private bool _profileUnavailable;

  private bool _loadingPlayers = false;
  private List<TeamPlayerDto>? _players;

  private StadiumDetailDto? _stadium;
  private bool _loadingStadium = false;

  private List<TeamHonourDto>? _teamHonours;
  private string _trophyFilter = "all";
  private int _expandedTrophy;

  private bool _isGalleryOpen;
  private int _activeGalleryIndex;
  private List<string>? _galleryUrls;

  private bool IsExternalTeam => _team?.Id == 0;

  private DateOnly _matchesFrom = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
  private DateOnly _matchesTo   = DateOnly.FromDateTime(DateTime.Today.AddDays(30));

  // player
  private PlayerViewMode _playerView = PlayerViewMode.Cutouts;

  private enum PlayerViewMode
  {
    Cutouts,
    Thumbs,
    Renders,
    Cartoon
  }

  private string PickPlayerImage(TeamPlayerDto p)
  {
    return _playerView switch
    {
      PlayerViewMode.Cutouts => p.CutoutUrl ?? p.ThumbUrl ?? "/images/icons/soccer-player.png",
      PlayerViewMode.Renders => p.RenderUrl ?? p.ThumbUrl ?? "/images/icons/soccer-player.png",
      PlayerViewMode.Cartoon => p.CartoonUrl ?? p.CutoutUrl ?? p.ThumbUrl ?? "/images/icons/soccer-player.png",
      _ => p.ThumbUrl ?? "/images/icons/soccer-player.png",
    };
  }

  private static string ToCssColor(string? value)
  {
    if (string.IsNullOrWhiteSpace(value)) return "transparent";
    var v = value!.Trim();
    if (v.StartsWith("#")) return v;
    if (v.Length == 6 && System.Text.RegularExpressions.Regex.IsMatch(v, @"^[0-9A-Fa-f]+$")) return "#" + v;
    return v;
  }

  private IEnumerable<TeamHonourDto> GetFilteredTeamHonours()
  {
    if (_teamHonours == null) return Enumerable.Empty<TeamHonourDto>();
    if (_trophyFilter == "all") return _teamHonours;
    return _teamHonours.Where(h => string.Equals(h.TypeGuess, _trophyFilter, StringComparison.OrdinalIgnoreCase));
  }

  private async Task GoBack()
  {
    await JSRuntime.InvokeVoidAsync("soccerBlastBack");
  }

  protected override async Task OnParametersSetAsync()
  {
    // Stop existing loop if team ID changed
    _syncLoop?.Stop();
    _syncLoop?.Dispose();
    _syncLoop = null;

    _loading = true;
    _toast = null;
    _team = null;
    _profileUnavailable = false;
    StateHasChanged();

    try
    {
      if (string.IsNullOrWhiteSpace(Id)) return;
      using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
      _team = await Api.GetTeamAsync(Id!, cts.Token);
      if (_team != null && _team.Id != 0)
      {
        StartAutoSync();
        _ = InvokeAsync(SyncProfileInBackground);
      }
      if (_team != null && !string.IsNullOrWhiteSpace(_team.SportsDbTeamId))
      {
        try
        {
          _teamHonours = await Api.GetTeamHonoursAsync(_team.SportsDbTeamId, cts.Token);
        }
        catch
        {
          _teamHonours = null; // honours optional; team page still works
        }
      }
      else
        _teamHonours = null;
    }
    catch (OperationCanceledException)
    {
      _toast = "Request timed out. The API may be slow or unavailable.";
    }
    catch (HttpRequestException)
    {
      _toast = "Could not reach the API. Make sure SoccerBlast.Api is running (e.g. dotnet run --project SoccerBlast.Api).";
    }
    catch (Exception ex)
    {
      var msg = ex.Message;
      if (msg.Length > 80) msg = msg.Substring(0, 77) + "...";
      _toast = $"Load failed: {msg}";
    }
    finally
    {
      _loading = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void StartAutoSync()
  {
    if (_profileUnavailable) return;
    _syncLoop = new AutoSyncLoop(TimeSpan.FromSeconds(60), async _ =>
    {
      if (!_profileUnavailable && (_team?.Profile == null || string.IsNullOrWhiteSpace(_team.SportsDbTeamId)))
        await SyncProfileInBackground();
    });
    _syncLoop.Start();
  }

  private DateTime _lastSyncAttemptUtc = DateTime.MinValue;

  private async Task SyncProfileInBackground()
  {
    if (_syncing || _profileUnavailable || IsExternalTeam || _team?.Id == 0) return;
    if (DateTime.UtcNow - _lastSyncAttemptUtc < TimeSpan.FromMinutes(5)) return;
    _lastSyncAttemptUtc = DateTime.UtcNow;
    _syncing = true;

    try
    {
      var (ok, message) = await Api.SyncTeamProfileAsync(_team!.Id);

      if (!ok && (message.Contains("No SportsDB match", StringComparison.OrdinalIgnoreCase) || message.Contains("not found", StringComparison.OrdinalIgnoreCase)))
      {
        _profileUnavailable = true;
        _syncLoop?.Stop();
      }

      // Reload team (profile may now be populated, or still null)
      _team = await Api.GetTeamAsync(Id!);

      if (!ok && !_profileUnavailable)
        _toast = message.Length > 60 ? message.Substring(0, 57) + "..." : message;

      await InvokeAsync(StateHasChanged);
    }
    catch (Exception ex)
    {
      _toast = $"Auto-sync: {ex.Message}";
      await InvokeAsync(StateHasChanged);
    }
    finally
    {
      _syncing = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private async Task LoadPlayersTab()
  {
    _activeTab = "players";
    
    if (_players != null || _loadingPlayers || _team == null) return;

    _loadingPlayers = true;
    try
    {
      if (IsExternalTeam && !string.IsNullOrEmpty(_team?.SportsDbTeamId))
        _players = await Api.GetTeamPlayersByExternalIdAsync(_team.SportsDbTeamId!);
      else if (_team?.Id > 0)
        _players = await Api.GetTeamPlayersAsync(_team.Id);
    }
    catch (Exception ex)
    {
      _toast = $"Failed to load players: {ex.Message}";
    }
    finally
    {
      _loadingPlayers = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void GoPlayer(TeamPlayerDto p)
  {
    if (!string.IsNullOrWhiteSpace(p.SportsDbPlayerId))
      Nav.NavigateTo($"/player/{p.SportsDbPlayerId}");
  }

  private void OpenGallery(int index)
  {
    if (_team?.Profile?.FanartUrls == null || _team.Profile.FanartUrls.Count == 0)
      return;
    _galleryUrls = _team.Profile.FanartUrls;
    _activeGalleryIndex = Math.Clamp(index, 0, _team.Profile.FanartUrls.Count - 1);
    _isGalleryOpen = true;
  }

  private void OpenStadiumGallery(int index)
  {
    if (_stadium?.FanartUrls == null || _stadium.FanartUrls.Count == 0)
      return;
    _galleryUrls = _stadium.FanartUrls;
    _activeGalleryIndex = Math.Clamp(index, 0, _stadium.FanartUrls.Count - 1);
    _isGalleryOpen = true;
  }

  private void CloseGallery()
  {
    _isGalleryOpen = false;
  }

  private void NextGalleryImage()
  {
    if (_galleryUrls == null || _galleryUrls.Count == 0) return;
    _activeGalleryIndex = (_activeGalleryIndex + 1) % _galleryUrls.Count;
  }

  private void PrevGalleryImage()
  {
    if (_galleryUrls == null || _galleryUrls.Count == 0) return;
    _activeGalleryIndex = (_activeGalleryIndex - 1 + _galleryUrls.Count) % _galleryUrls.Count;
  }

  private async Task OnStadiumTabClick()
  {
    _activeTab = "stadium";
    await LoadStadiumIfNeeded();
    await Task.Yield();
    try { await JSRuntime.InvokeVoidAsync("soccerBlastMaps.resizeVenueMap", "stadium-map"); } catch { }
  }

  private async Task LoadStadiumIfNeeded()
  {
    if (_team == null || _stadium != null || _loadingStadium) return;
    if (string.IsNullOrWhiteSpace(_team.Profile?.StadiumName)) return;
    _loadingStadium = true;
    try
    {
      var teamId = IsExternalTeam && !string.IsNullOrWhiteSpace(_team.SportsDbTeamId)
        ? _team.SportsDbTeamId!
        : _team.Id.ToString();
      _stadium = await Api.GetTeamVenueAsync(teamId);
    }
    catch
    {
      _stadium = null;
    }
    finally
    {
      _loadingStadium = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  // player grouped by position
  private static int PositionSortOrder(string position)
  {
    var key = position.ToLowerInvariant();
    if (key.Contains("goalkeeper") || key == "goalkeeper") return 0;
    if (key.Contains("defen")) return 1;
    if (key.Contains("midfield")) return 2;
    if (key.Contains("forward") || key.Contains("striker") || key.Contains("attack")) return 3;
    if (key == "other") return 99;
    return 10; // other named positions (e.g. Left Winger) after main four
  }

  private void LoadMatchesTab()
  {
    _activeTab = "matches";
  }

  private Task OnMatchRangeChanged((DateOnly From, DateOnly To) r)
  {
    _matchesFrom = r.From;
    _matchesTo = r.To;
    return Task.CompletedTask;
  }

  public void Dispose()
  {
    _syncLoop?.Dispose();
  }

}
